---
interface Props {
  initial?: number;
  label?: string;
}

const { initial = 50, label } = Astro.props;
const indices = Array.from({ length: 8 }, (_, i) => 7 - i); // display order: bit 7 leftmost
const positionFromValue = (v: number) =>
  Math.min(Math.max(Math.round((v * 8) / 100), 0), 8);
const initialPos = positionFromValue(initial);
const initialPattern = initialPos === 0 ? 0 : (1 << initialPos) - 1;
const fmt2 = (v: number) => v.toString(16).toUpperCase().padStart(2, '0');
const fmt8 = (v: number) => v.toString(2).padStart(8, '0');
---

<div
  class="led-bar-meter not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-led-bar
  data-initial={initial}
  style="container-type: inline-size;"
>
  {label && <div class="panel-title mb-4">{label}</div>}

  <div class="controls">
    <label class="input-label">
      <span class="ctrl-tag">Input</span>
      <input
        type="number"
        min="0"
        max="100"
        value={initial}
        data-input
        class="value-input"
      />
      <span class="ctrl-hint">(0–100)</span>
    </label>
    <button type="button" data-play class="play-btn">
      <span data-play-label>⏸ Pause auto-pulse</span>
    </button>
  </div>

  <div class="led-stage">
    <div class="led-row">
      {indices.map((i, n) => (
        <>
          {n === 4 && <div class="nibble-spacer"></div>}
          <div
            class="bit"
            data-bit={i}
            data-on={((initialPattern >> i) & 1) === 1 ? 'true' : 'false'}
          >
            <span class="led-bezel">
              <span class="led"></span>
            </span>
            <span class="bit-num">{i}</span>
          </div>
        </>
      ))}
    </div>
  </div>

  <div class="readout">
    <div class="readout-row">
      <span class="r-tag">Position</span>
      <span class="r-val r-pos" data-out="position">{initialPos}</span>
      <span class="r-sep">/8</span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Binary</span>
      <span class="r-val r-bin">%<span data-out="bin">{fmt8(initialPattern)}</span></span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Hex</span>
      <span class="r-val r-hex">$<span data-out="hex">{fmt2(initialPattern)}</span></span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Decimal</span>
      <span class="r-val r-dec" data-out="dec">{initialPattern}</span>
    </div>
  </div>
</div>

<style>
  .led-bar-meter .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid theme('colors.ink.700');
  }
  .led-bar-meter .input-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }
  .led-bar-meter .ctrl-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.400');
    font-weight: 600;
  }
  .led-bar-meter .value-input {
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 1rem;
    font-weight: 700;
    color: theme('colors.amber.300');
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 6px 10px;
    width: 5rem;
    text-align: center;
  }
  .led-bar-meter .value-input:focus {
    outline: none;
    border-color: theme('colors.accent.DEFAULT');
  }
  .led-bar-meter .ctrl-hint {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    color: theme('colors.ink.500');
  }
  .led-bar-meter .play-btn {
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    font-weight: 600;
    color: theme('colors.ink.200');
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 6px 12px;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .led-bar-meter .play-btn:hover {
    border-color: theme('colors.accent.DEFAULT');
    color: theme('colors.accent.DEFAULT');
  }

  .led-bar-meter .led-stage {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 1rem;
  }
  .led-bar-meter .led-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) 0.5rem repeat(4, minmax(0, 1fr));
    column-gap: 0.5rem;
    align-items: end;
    width: 100%;
    max-width: 32rem;
  }
  .led-bar-meter .nibble-spacer {
    width: 0.5rem;
  }
  .led-bar-meter .bit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 4px;
  }
  .led-bar-meter .bit-num {
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    color: theme('colors.ink.500');
    font-variant-numeric: tabular-nums;
  }
  .led-bar-meter .led-bezel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    padding: 3px;
    background: linear-gradient(145deg, theme('colors.ink.950'), theme('colors.ink.700'));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }
  .led-bar-meter .led {
    display: inline-block;
    border-radius: 3px;
    width: clamp(14px, 3.5cqi, 22px);
    height: clamp(48px, 11cqi, 72px);
    background: linear-gradient(180deg, #1a1d22 0%, #050608 60%, #000 100%);
    box-shadow:
      inset 0 0 6px rgba(0, 0, 0, 0.9),
      inset 0 1px 1px rgba(0, 0, 0, 0.8);
    transition: all 0.12s ease-out;
  }

  /* GREEN — bits 0, 1, 2 (the bottom of the bar, safe zone) */
  .led-bar-meter .bit[data-bit='0'][data-on='true'] .led,
  .led-bar-meter .bit[data-bit='1'][data-on='true'] .led,
  .led-bar-meter .bit[data-bit='2'][data-on='true'] .led {
    background: linear-gradient(180deg,
      color-mix(in srgb, theme('colors.accent.DEFAULT') 75%, white) 0%,
      theme('colors.accent.DEFAULT') 55%,
      theme('colors.accent.dim') 100%);
    box-shadow:
      0 0 14px theme('colors.accent.DEFAULT'),
      0 0 4px theme('colors.accent.DEFAULT'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }
  .led-bar-meter .bit[data-bit='0'][data-on='true'] .bit-num,
  .led-bar-meter .bit[data-bit='1'][data-on='true'] .bit-num,
  .led-bar-meter .bit[data-bit='2'][data-on='true'] .bit-num {
    color: theme('colors.accent.DEFAULT');
  }

  /* YELLOW — bits 3, 4, 5 (middle, warning zone) */
  .led-bar-meter .bit[data-bit='3'][data-on='true'] .led,
  .led-bar-meter .bit[data-bit='4'][data-on='true'] .led,
  .led-bar-meter .bit[data-bit='5'][data-on='true'] .led {
    background: linear-gradient(180deg,
      color-mix(in srgb, theme('colors.amber.300') 70%, white) 0%,
      theme('colors.amber.300') 55%,
      theme('colors.amber.500') 100%);
    box-shadow:
      0 0 14px theme('colors.amber.300'),
      0 0 4px theme('colors.amber.300'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }
  .led-bar-meter .bit[data-bit='3'][data-on='true'] .bit-num,
  .led-bar-meter .bit[data-bit='4'][data-on='true'] .bit-num,
  .led-bar-meter .bit[data-bit='5'][data-on='true'] .bit-num {
    color: theme('colors.amber.300');
  }

  /* RED — bits 6, 7 (top, danger zone) */
  .led-bar-meter .bit[data-bit='6'][data-on='true'] .led,
  .led-bar-meter .bit[data-bit='7'][data-on='true'] .led {
    background: linear-gradient(180deg,
      color-mix(in srgb, theme('colors.rose.400') 70%, white) 0%,
      theme('colors.rose.400') 55%,
      theme('colors.rose.600') 100%);
    box-shadow:
      0 0 14px theme('colors.rose.400'),
      0 0 4px theme('colors.rose.400'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }
  .led-bar-meter .bit[data-bit='6'][data-on='true'] .bit-num,
  .led-bar-meter .bit[data-bit='7'][data-on='true'] .bit-num {
    color: theme('colors.rose.300');
  }

  .led-bar-meter .readout {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid theme('colors.ink.700');
  }
  @container (max-width: 480px) {
    .led-bar-meter .readout {
      grid-template-columns: 1fr;
    }
  }
  .led-bar-meter .readout-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.95rem;
  }
  .led-bar-meter .r-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.400');
    font-weight: 600;
    min-width: 4.5rem;
  }
  .led-bar-meter .r-val { font-weight: 600; }
  .led-bar-meter .r-pos { color: theme('colors.ink.100'); }
  .led-bar-meter .r-bin { color: theme('colors.accent.DEFAULT'); }
  .led-bar-meter .r-hex { color: theme('colors.sky.300'); }
  .led-bar-meter .r-dec { color: theme('colors.amber.300'); }
  .led-bar-meter .r-sep { color: theme('colors.ink.500'); font-size: 0.85rem; }
</style>

<script>
  const wireLedBar = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const initial = Number(root.dataset.initial ?? '128');
    const bitCells = Array.from(root.querySelectorAll<HTMLElement>('.bit[data-bit]'));
    const input = root.querySelector<HTMLInputElement>('[data-input]');
    const playBtn = root.querySelector<HTMLButtonElement>('[data-play]');
    const playLabel = root.querySelector<HTMLElement>('[data-play-label]');

    const out = {
      position: root.querySelector<HTMLElement>('[data-out="position"]'),
      bin: root.querySelector<HTMLElement>('[data-out="bin"]'),
      hex: root.querySelector<HTMLElement>('[data-out="hex"]'),
      dec: root.querySelector<HTMLElement>('[data-out="dec"]'),
    };

    const fmt2 = (v: number) => v.toString(16).toUpperCase().padStart(2, '0');
    const fmt8 = (v: number) => v.toString(2).padStart(8, '0');

    let value = initial;
    let auto = true;
    let dir = 1;

    const positionFromValue = (v: number) => {
      const p = Math.round((v * 8) / 100);
      return Math.min(Math.max(p, 0), 8);
    };

    const patternFromPosition = (p: number) => (p === 0 ? 0 : ((1 << p) - 1) & 0xff);

    const render = () => {
      const p = positionFromValue(value);
      const pattern = patternFromPosition(p);
      if (out.position) out.position.textContent = String(p);
      if (out.bin) out.bin.textContent = fmt8(pattern);
      if (out.hex) out.hex.textContent = fmt2(pattern);
      if (out.dec) out.dec.textContent = String(pattern);
      for (const cell of bitCells) {
        const i = Number(cell.dataset.bit);
        cell.dataset.on = ((pattern >> i) & 1) === 1 ? 'true' : 'false';
      }
    };

    const updateButton = () => {
      if (playLabel) playLabel.textContent = auto ? '⏸ Pause auto-pulse' : '▶ Resume auto-pulse';
    };

    playBtn?.addEventListener('click', () => {
      auto = !auto;
      updateButton();
    });

    input?.addEventListener('input', () => {
      const n = Number(input.value);
      if (!Number.isNaN(n)) {
        value = Math.max(0, Math.min(100, Math.floor(n)));
        auto = false;
        updateButton();
        render();
      }
    });

    // Auto-pulse: triangle wave 0..100..0
    const STEP_MS = 60;
    const PER_TICK = 2;

    const tick = () => {
      if (!auto) return;
      value += dir * PER_TICK;
      if (value >= 100) { value = 100; dir = -1; }
      else if (value <= 0) { value = 0; dir = 1; }
      if (input) input.value = String(value);
      render();
    };

    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        (e.target as HTMLElement).dataset.visible = e.isIntersecting ? '1' : '0';
      }
    });
    obs.observe(root);

    window.setInterval(() => {
      if (root.dataset.visible === '0') return;
      tick();
    }, STEP_MS);

    render();
    updateButton();
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-led-bar]').forEach(wireLedBar);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
