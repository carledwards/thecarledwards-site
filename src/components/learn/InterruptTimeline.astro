---
// A static, animated SVG-ish timeline showing how an interrupt
// pulls the CPU out of the main program, runs the ISR, and returns.
---

<figure class="irq-timeline not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner">
  <figcaption class="irq-caption">
    <span class="irq-cap-label">Timeline</span>
    The CPU is running the main program. A peripheral pulls IRQ. The
    CPU saves state, jumps to the ISR, runs it, then returns and
    picks up exactly where it left off.
  </figcaption>

  <div class="irq-stage">
    <div class="lane lane-main" data-lane="main">
      <span class="lane-tag">main</span>
      <span class="lane-bar" data-segment="pre"></span>
      <span class="lane-gap" aria-hidden="true">
        <span class="gap-arrow gap-arrow-down" aria-label="Save state, jump to ISR">↓</span>
      </span>
      <span class="lane-bar lane-bar-faded" data-segment="suspended"></span>
      <span class="lane-gap" aria-hidden="true">
        <span class="gap-arrow gap-arrow-up" aria-label="Restore state, return">↑</span>
      </span>
      <span class="lane-bar" data-segment="post"></span>
    </div>

    <div class="lane lane-isr" data-lane="isr">
      <span class="lane-tag">ISR</span>
      <span class="lane-spacer"></span>
      <span class="lane-bar lane-bar-isr" data-segment="isr"></span>
      <span class="lane-spacer"></span>
    </div>

    <div class="markers">
      <span class="marker marker-irq">IRQ asserted</span>
      <span class="marker marker-rti">RTI returns</span>
    </div>
  </div>
</figure>

<style>
  .irq-timeline .irq-caption {
    font-family: theme('fontFamily.sans');
    font-size: 0.95rem;
    line-height: 1.5;
    color: theme('colors.ink.300');
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid theme('colors.ink.700');
  }
  .irq-timeline .irq-cap-label {
    display: inline-block;
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.400');
    margin-right: 0.5rem;
    font-weight: 600;
  }

  .irq-timeline .irq-stage {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 0.5rem;
  }

  .irq-timeline .lane {
    display: grid;
    grid-template-columns: 4rem 3fr 1rem 2fr 1rem 3fr;
    align-items: center;
    gap: 0.4rem;
  }
  .irq-timeline .lane-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: theme('colors.ink.400');
    text-align: right;
    padding-right: 0.5rem;
    font-weight: 600;
  }

  .irq-timeline .lane-bar {
    height: 16px;
    border-radius: 8px;
    background: linear-gradient(90deg,
      rgba(126, 231, 135, 0.4),
      rgba(86, 211, 100, 0.55));
    border: 1px solid rgba(126, 231, 135, 0.5);
  }
  .irq-timeline .lane-bar-faded {
    background: rgba(126, 231, 135, 0.06);
    border: 1px dashed rgba(126, 231, 135, 0.25);
  }
  .irq-timeline .lane-bar-isr {
    background: linear-gradient(90deg,
      rgba(244, 63, 94, 0.35),
      rgba(244, 63, 94, 0.55));
    border: 1px solid rgba(244, 63, 94, 0.55);
  }
  .irq-timeline .lane-spacer {
    /* invisible placeholder so the ISR bar lines up under the gap */
  }

  .irq-timeline .lane-gap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 24px;
  }
  .irq-timeline .gap-arrow {
    font-family: theme('fontFamily.mono');
    font-size: 1.3rem;
    line-height: 1;
    color: theme('colors.rose.300');
    font-weight: 700;
  }

  .irq-timeline .markers {
    display: grid;
    grid-template-columns: 4rem 3fr 1rem 2fr 1rem 3fr;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .irq-timeline .marker {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: theme('colors.rose.300');
    text-align: center;
    white-space: nowrap;
  }
  .irq-timeline .marker-irq {
    grid-column: 3;
  }
  .irq-timeline .marker-rti {
    grid-column: 5;
  }

  @media (max-width: 540px) {
    .irq-timeline .lane,
    .irq-timeline .markers {
      grid-template-columns: 3rem 3fr 0.75rem 2fr 0.75rem 3fr;
    }
    .irq-timeline .marker {
      font-size: 0.6rem;
    }
  }
</style>
