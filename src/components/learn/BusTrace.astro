---
const baseAddr = 0x8000;
const transactions = [
  { i: 2, byte: 0x0A, rw: 'W' },
  { i: 5, byte: 0xC3, rw: 'W' },
  { i: 0, byte: 0xFF, rw: 'W' },
  { i: 2, byte: 0x0A, rw: 'R' },
  { i: 7, byte: 0x42, rw: 'W' },
];
const txJson = JSON.stringify(transactions);

// Pre-render a long square wave path so we can scroll it left.
// Each "tick" = high block (10w) then low block (10w) → 20w period.
// Make the path 800w (40 ticks) so the scroll animation has plenty of repeats.
const wavePeriod = 20;
const waveTicks = 40;
const waveSegments: string[] = [];
for (let t = 0; t < waveTicks; t++) {
  const x = t * wavePeriod;
  // rising edge
  waveSegments.push(`L${x},6`);
  waveSegments.push(`L${x + wavePeriod / 2},6`);
  // falling edge
  waveSegments.push(`L${x + wavePeriod / 2},34`);
  waveSegments.push(`L${x + wavePeriod},34`);
}
const wavePath = `M0,34 L0,6 ${waveSegments.join(' ')}`;
---

<div
  class="bus-trace not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-bus-trace
  data-transactions={txJson}
>
  {/* Top narration — what Bill is asking Emily */}
  <div class="narration" data-narration>
    Bill says to Emily, “Save <code>$0A</code> in box <code>$8002</code>.”
  </div>

  {/* Clock strip */}
  <div class="clock-strip">
    <div class="clock-tag">CLK</div>
    <svg class="clock-wave" viewBox="0 0 200 40" preserveAspectRatio="none" aria-hidden="true">
      <g class="wave-track">
        <path class="wave" d={wavePath} />
        <path class="wave" d={wavePath} transform={`translate(${wavePeriod * waveTicks},0)`} />
      </g>
    </svg>
    <div class="clock-tick" data-tick></div>
    <button type="button" class="play-btn" data-play-pause aria-label="Pause">
      <span data-play-label>⏸ Pause</span>
    </button>
  </div>

  {/* Stage: CPU - Bus - Memory */}
  <div class="bus-stage">
    <div class="block cpu-block">
      <div class="block-title">CPU</div>
      <div class="block-name">"Bill"</div>
      <div class="cpu-acc" data-acc>
        <span class="acc-label">A</span>
        <span class="acc-value" data-out="acc">$00</span>
      </div>
      <div class="cpu-pins">
        <div class="pin pin-rw" data-pin="rw">R/W</div>
        <div class="pin pin-state" data-pin="state">idle</div>
      </div>
    </div>

    <div class="bus-lanes">
      <div class="bus-lane lane-addr" data-lane="addr">
        <div class="lane-label">ADDR</div>
        <div class="lane-track">
          <div class="lane-chip lane-chip-static" data-out="addr">$0000</div>
        </div>
      </div>
      <div class="bus-lane lane-data" data-lane="data" data-pkt="hidden">
        <div class="lane-label">DATA</div>
        <div class="lane-track">
          <div class="lane-chip lane-chip-packet" data-out="data">$00</div>
        </div>
      </div>
      <div class="bus-lane lane-rw" data-lane="rw">
        <div class="lane-label">R/W</div>
        <div class="lane-track">
          <div class="lane-chip lane-chip-static" data-out="rw">—</div>
        </div>
      </div>
    </div>

    <div class="block mem-block">
      <div class="block-title">MEMORY</div>
      <div class="block-name">"Emily"</div>
      <div class="mem-cells">
        {Array.from({ length: 8 }, (_, i) => {
          const addr = (baseAddr + i).toString(16).toUpperCase().padStart(4, '0');
          return (
            <div class="mem-cell" data-cell={i}>
              <span class="cell-addr">${addr}</span>
              <span class="cell-value" data-cell-value={i}>$00</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div class="caption" aria-live="polite" data-caption>
    Pulse → CPU sets the address → CPU sets data + R/W → Memory takes (or
    sends) the byte.
  </div>
</div>

<style>
  .bus-trace {
    --accent: theme('colors.accent.DEFAULT');
    --sky: theme('colors.sky.300');
    --amber: theme('colors.amber.300');
    --rose: theme('colors.rose.300');
    --ink-700: theme('colors.ink.700');
    --ink-800: theme('colors.ink.800');
    --ink-900: theme('colors.ink.900');
    --ink-300: theme('colors.ink.300');
    --ink-400: theme('colors.ink.400');
    --ink-500: theme('colors.ink.500');
    container-type: inline-size;
  }

  /* Top narration */
  .bus-trace .narration {
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    line-height: 1.5;
    color: theme('colors.ink.100');
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--ink-700);
    text-align: center;
  }
  .bus-trace .narration code {
    font-family: theme('fontFamily.mono');
    font-size: 0.95em;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--ink-700);
    border-radius: 4px;
    padding: 1px 6px;
    color: var(--accent);
  }

  /* Clock strip */
  .bus-trace .clock-strip {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--ink-700);
  }
  .bus-trace .play-btn {
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-200);
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--ink-700);
    border-radius: 6px;
    padding: 5px 12px;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    min-width: 5.5rem;
    text-align: center;
  }
  .bus-trace .play-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .bus-trace .clock-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-400);
    font-weight: 600;
  }
  .bus-trace .clock-wave {
    width: 100%;
    height: 28px;
    overflow: hidden;
  }
  .bus-trace .clock-wave .wave-track {
    animation: bus-wave-scroll 12.8s linear infinite;
    transform: translateX(0);
  }
  .bus-trace .clock-wave .wave {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linejoin: miter;
  }
  @keyframes bus-wave-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-160px); } /* 8 ticks at 800ms each */
  }
  .bus-trace .clock-tick {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: var(--ink-700);
    border: 1px solid var(--ink-700);
    transition: background 0.1s, box-shadow 0.1s;
  }
  .bus-trace .clock-tick[data-active='true'] {
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  /* Stage layout */
  .bus-trace .bus-stage {
    display: grid;
    grid-template-columns: minmax(7rem, 1fr) minmax(8rem, 2fr) minmax(11rem, 1.4fr);
    gap: 0.75rem;
    align-items: stretch;
  }

  /* Generic block (CPU / MEM) */
  .bus-trace .block {
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--ink-700);
    border-radius: 8px;
    padding: 0.75rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .bus-trace .block-title {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-400);
    font-weight: 600;
  }
  .bus-trace .block-name {
    font-family: theme('fontFamily.mono');
    font-size: 1rem;
    font-weight: 700;
    color: theme('colors.ink.100');
  }

  .bus-trace .cpu-block {
    align-items: center;
    text-align: center;
  }
  .bus-trace .cpu-acc {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--ink-700);
    background: rgba(0, 0, 0, 0.45);
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    font-weight: 600;
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
  }
  .bus-trace .cpu-acc .acc-label {
    color: var(--ink-500);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .bus-trace .cpu-acc .acc-value {
    color: var(--amber);
    font-variant-numeric: tabular-nums;
  }
  .bus-trace .cpu-acc[data-active='write'] {
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.18);
    box-shadow: 0 0 10px rgba(244, 63, 94, 0.4);
  }
  .bus-trace .cpu-acc[data-active='read'] {
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.18);
    box-shadow: 0 0 10px rgba(126, 231, 135, 0.4);
  }
  .bus-trace .cpu-pins {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .bus-trace .pin {
    font-family: theme('fontFamily.mono');
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--ink-700);
    border-radius: 4px;
    padding: 2px 6px;
    color: var(--ink-400);
    background: rgba(0, 0, 0, 0.3);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .bus-trace .pin[data-active='write'] {
    color: var(--rose);
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.15);
  }
  .bus-trace .pin[data-active='read'] {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.15);
  }

  /* Bus lanes */
  .bus-trace .bus-lanes {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
  }
  .bus-trace .bus-lane {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.5rem;
    align-items: center;
  }
  .bus-trace .lane-label {
    font-family: theme('fontFamily.mono');
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-400);
    font-weight: 600;
    text-align: right;
  }
  .bus-trace .lane-track {
    position: relative;
    height: 30px;
    border: 1px dashed var(--ink-700);
    background: rgba(0, 0, 0, 0.25);
    border-radius: 999px;
  }
  .bus-trace .lane-chip {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    padding: 3px 10px;
    border-radius: 999px;
    font-family: theme('fontFamily.mono');
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--ink-700);
    color: var(--ink-400);
    white-space: nowrap;
  }

  /* Static chips (ADDR, R/W) — sit centered, light up when active */
  .bus-trace .lane-chip-static {
    left: 50%;
    transform: translate(-50%, -50%);
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .bus-trace .lane-addr[data-active='true'] .lane-chip-static {
    color: var(--sky);
    border-color: var(--sky);
    background: rgba(56, 189, 248, 0.15);
    box-shadow: 0 0 8px rgba(56, 189, 248, 0.35);
  }
  .bus-trace .lane-rw[data-active='write'] .lane-chip-static {
    color: var(--rose);
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.15);
    box-shadow: 0 0 8px rgba(244, 63, 94, 0.35);
  }
  .bus-trace .lane-rw[data-active='read'] .lane-chip-static {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.15);
    box-shadow: 0 0 8px rgba(126, 231, 135, 0.35);
  }

  /* DATA packet — slides full track width, direction-correct */
  .bus-trace .lane-chip-packet {
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    /* No transitions by default — appearance/disappearance is instant
       so the chip can't visually drift from/to center. */
  }
  /* During the slide phase (-end states) we transition position only. */
  .bus-trace .lane-data[data-pkt='write-end'] .lane-chip-packet,
  .bus-trace .lane-data[data-pkt='read-end'] .lane-chip-packet {
    transition:
      left 1500ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 1500ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* Write: chip's left edge at left edge of track → chip's right edge at right edge */
  .bus-trace .lane-data[data-pkt='write-start'] .lane-chip-packet {
    left: 0;
    transform: translate(0, -50%);
    opacity: 1;
    color: var(--rose);
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.2);
    box-shadow: 0 0 10px rgba(244, 63, 94, 0.45);
  }
  .bus-trace .lane-data[data-pkt='write-end'] .lane-chip-packet {
    left: 100%;
    transform: translate(-100%, -50%);
    opacity: 1;
    color: var(--rose);
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.2);
    box-shadow: 0 0 10px rgba(244, 63, 94, 0.45);
  }
  /* Read: chip starts at the right edge → slides to the left edge */
  .bus-trace .lane-data[data-pkt='read-start'] .lane-chip-packet {
    left: 100%;
    transform: translate(-100%, -50%);
    opacity: 1;
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.2);
    box-shadow: 0 0 10px rgba(126, 231, 135, 0.45);
  }
  .bus-trace .lane-data[data-pkt='read-end'] .lane-chip-packet {
    left: 0;
    transform: translate(0, -50%);
    opacity: 1;
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.2);
    box-shadow: 0 0 10px rgba(126, 231, 135, 0.45);
  }

  /* Memory cells */
  .bus-trace .mem-cells {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.25rem;
    margin-top: 0.25rem;
  }
  .bus-trace .mem-cell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--ink-700);
    border-radius: 4px;
    padding: 3px 8px;
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    transition: border-color 0.15s, background 0.15s;
  }
  .bus-trace .mem-cell .cell-addr {
    color: var(--ink-500);
  }
  .bus-trace .mem-cell .cell-value {
    color: var(--amber);
    font-weight: 600;
  }
  .bus-trace .mem-cell[data-active='write'] {
    border-color: var(--rose);
    background: rgba(244, 63, 94, 0.18);
    box-shadow: 0 0 8px rgba(244, 63, 94, 0.3);
  }
  .bus-trace .mem-cell[data-active='read'] {
    border-color: var(--accent);
    background: rgba(126, 231, 135, 0.15);
    box-shadow: 0 0 8px rgba(126, 231, 135, 0.3);
  }

  /* Caption */
  .bus-trace .caption {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--ink-700);
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    color: var(--ink-400);
    text-align: center;
    line-height: 1.5;
  }

  /* Narrow viewports — stack vertically */
  @container (max-width: 640px) {
    .bus-trace .bus-stage {
      grid-template-columns: 1fr;
    }
    .bus-trace .bus-lanes {
      gap: 0.4rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .bus-trace .clock-wave .wave-track {
      animation: none;
    }
  }
</style>

<script>
  type Tx = { i: number; byte: number; rw: 'W' | 'R' };

  const STEP_MS = 1600;

  const wireTrace = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    let txs: Tx[] = [];
    try {
      txs = JSON.parse(root.dataset.transactions ?? '[]');
    } catch {
      txs = [];
    }
    if (txs.length === 0) return;

    const tick = root.querySelector<HTMLElement>('[data-tick]');
    const cpuRwPin = root.querySelector<HTMLElement>('[data-pin="rw"]');
    const cpuStatePin = root.querySelector<HTMLElement>('[data-pin="state"]');
    const acc = root.querySelector<HTMLElement>('[data-acc]');
    const accValueEl = root.querySelector<HTMLElement>('[data-out="acc"]');
    let accValue = 0;
    const writeAcc = (v: number) => {
      accValue = v & 0xff;
      if (accValueEl) accValueEl.textContent = fmt2(accValue);
    };

    const lanes = {
      addr: root.querySelector<HTMLElement>('[data-lane="addr"]'),
      data: root.querySelector<HTMLElement>('[data-lane="data"]'),
      rw:   root.querySelector<HTMLElement>('[data-lane="rw"]'),
    };
    const out = {
      addr: root.querySelector<HTMLElement>('[data-out="addr"]'),
      data: root.querySelector<HTMLElement>('[data-out="data"]'),
      rw:   root.querySelector<HTMLElement>('[data-out="rw"]'),
    };
    const cells = Array.from(root.querySelectorAll<HTMLElement>('.mem-cell'));
    const cellValues = cells.map((c) =>
      c.querySelector<HTMLElement>('[data-cell-value]')
    );
    const memValues: number[] = new Array(cells.length).fill(0);

    const caption = root.querySelector<HTMLElement>('[data-caption]');
    const narration = root.querySelector<HTMLElement>('[data-narration]');

    const fmt2 = (v: number) => `$${v.toString(16).toUpperCase().padStart(2, '0')}`;
    const fmt4 = (v: number) => `$${v.toString(16).toUpperCase().padStart(4, '0')}`;

    const clearActive = () => {
      tick?.removeAttribute('data-active');
      cpuRwPin?.removeAttribute('data-active');
      cpuStatePin?.removeAttribute('data-active');
      acc?.removeAttribute('data-active');
      for (const lane of Object.values(lanes)) lane?.removeAttribute('data-active');
      lanes.data?.setAttribute('data-pkt', 'hidden');
      for (const c of cells) c.removeAttribute('data-active');
    };

    const setNarration = (tx: Tx) => {
      if (!narration) return;
      const addr = fmt4(0x8000 + tx.i);
      const byte = fmt2(tx.byte);
      narration.innerHTML = tx.rw === 'W'
        ? `Bill says to Emily, &ldquo;Save <code>${byte}</code> in box <code>${addr}</code>.&rdquo;`
        : `Bill asks Emily, &ldquo;What&rsquo;s in box <code>${addr}</code>?&rdquo;`;
    };

    let txIdx = 0;
    let phase = 0;

    const step = () => {
      const tx = txs[txIdx];
      const addrFull = 0x8000 + tx.i;
      const cell = cells[tx.i];
      const cellValEl = cellValues[tx.i];
      const isWrite = tx.rw === 'W';

      switch (phase) {
        case 0: { // pulse: address on the bus
          setNarration(tx);
          tick?.setAttribute('data-active', 'true');
          if (out.addr) out.addr.textContent = fmt4(addrFull);
          lanes.addr?.setAttribute('data-active', 'true');
          if (cpuStatePin) cpuStatePin.textContent = isWrite ? 'write' : 'read';
          cpuStatePin?.setAttribute('data-active', isWrite ? 'write' : 'read');
          if (isWrite) {
            // For a write, the CPU has already loaded A with the value. Show it.
            writeAcc(tx.byte);
            acc?.setAttribute('data-active', 'write');
          }
          if (caption) caption.textContent = isWrite
            ? `A holds ${fmt2(tx.byte)}. CPU puts ${fmt4(addrFull)} on the address lines.`
            : `CPU puts ${fmt4(addrFull)} on the address lines, ready to receive into A.`;
          break;
        }
        case 1: { // R/W set; on write, packet leaves A and slides to memory
          if (out.rw) out.rw.textContent = isWrite ? 'WRITE' : 'READ';
          lanes.rw?.setAttribute('data-active', isWrite ? 'write' : 'read');
          cpuRwPin?.setAttribute('data-active', isWrite ? 'write' : 'read');

          if (isWrite) {
            if (out.data) out.data.textContent = fmt2(tx.byte);
            lanes.data?.setAttribute('data-pkt', 'write-start');
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                lanes.data?.setAttribute('data-pkt', 'write-end');
              });
            });
            if (caption) caption.textContent = `R/W → WRITE. The byte from A goes onto the data lines.`;
          } else {
            if (caption) caption.textContent = `R/W → READ. CPU listens for the byte.`;
          }
          break;
        }
        case 2: { // Memory reacts
          cell?.setAttribute('data-active', isWrite ? 'write' : 'read');
          if (isWrite) {
            memValues[tx.i] = tx.byte;
            if (cellValEl) cellValEl.textContent = fmt2(tx.byte);
            if (caption) caption.textContent = `Emily takes ${fmt2(tx.byte)} into box ${fmt4(addrFull)}.`;
          } else {
            const v = memValues[tx.i];
            if (out.data) out.data.textContent = fmt2(v);
            lanes.data?.setAttribute('data-pkt', 'read-start');
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                lanes.data?.setAttribute('data-pkt', 'read-end');
              });
            });
            // Schedule A to receive the byte at the end of the slide
            window.setTimeout(() => {
              writeAcc(v);
              acc?.setAttribute('data-active', 'read');
            }, 1450);
            if (caption) caption.textContent = `Emily puts ${fmt2(v)} on the data lines; the byte travels to A.`;
          }
          break;
        }
        case 3: { // settle, advance
          clearActive();
          if (caption) caption.textContent = 'Idle — clock low, bus quiet.';
          txIdx = (txIdx + 1) % txs.length;
          break;
        }
      }

      phase = (phase + 1) % 4;
    };

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      // For reduced motion, just leave first state visible without animation.
      step();
      return;
    }

    // Pause when off-screen for perf
    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        (e.target as HTMLElement).dataset.visible = e.isIntersecting ? '1' : '0';
      }
    });
    obs.observe(root);

    // Play / pause button
    let paused = false;
    const playBtn = root.querySelector<HTMLButtonElement>('[data-play-pause]');
    const playLabel = root.querySelector<HTMLElement>('[data-play-label]');
    const updateButton = () => {
      if (playLabel) playLabel.textContent = paused ? '▶ Play' : '⏸ Pause';
      playBtn?.setAttribute('aria-label', paused ? 'Play' : 'Pause');
    };
    playBtn?.addEventListener('click', () => {
      paused = !paused;
      updateButton();
      if (paused) {
        // Freeze the wave too
        const waveTrack = root.querySelector<SVGElement>('.wave-track');
        if (waveTrack) waveTrack.style.animationPlayState = 'paused';
      } else {
        const waveTrack = root.querySelector<SVGElement>('.wave-track');
        if (waveTrack) waveTrack.style.animationPlayState = 'running';
      }
    });
    updateButton();

    window.setInterval(() => {
      if (paused) return;
      if (root.dataset.visible === '0') return;
      step();
    }, STEP_MS);
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-bus-trace]').forEach(wireTrace);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
