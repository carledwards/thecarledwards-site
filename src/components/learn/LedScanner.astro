---
interface Props {
  label?: string;
  speed?: number; // ms between steps
}

const { label, speed = 90 } = Astro.props;
const indices = Array.from({ length: 8 }, (_, i) => 7 - i);
const initial = 0;
const initialPattern = 1 << initial;
const fmt2 = (v: number) => v.toString(16).toUpperCase().padStart(2, '0');
const fmt8 = (v: number) => v.toString(2).padStart(8, '0');
---

<div
  class="led-scanner learn-device not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-led-scanner
  data-speed={speed}
  style="container-type: inline-size;"
>
  {label && <div class="panel-title mb-4">{label}</div>}

  <div class="controls">
    <span class="ctrl-tag">Scanner</span>
    <span class="ctrl-hint">One bit walks 0 → 7 → 0, all red</span>
    <button type="button" data-play class="play-btn">
      <span data-play-label>⏸ Pause</span>
    </button>
  </div>

  <div class="led-stage">
    <div class="led-row">
      {indices.map((i, n) => (
        <>
          {n === 4 && <div class="nibble-spacer"></div>}
          <div
            class="bit"
            data-bit={i}
            data-on={((initialPattern >> i) & 1) === 1 ? 'true' : 'false'}
          >
            <span class="led-bezel">
              <span class="led"></span>
            </span>
            <span class="bit-num">{i}</span>
          </div>
        </>
      ))}
    </div>
  </div>

  <div class="readout">
    <div class="readout-row">
      <span class="r-tag">Position</span>
      <span class="r-val r-pos" data-out="position">{initial}</span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Binary</span>
      <span class="r-val r-bin">%<span data-out="bin">{fmt8(initialPattern)}</span></span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Hex</span>
      <span class="r-val r-hex">$<span data-out="hex">{fmt2(initialPattern)}</span></span>
    </div>
    <div class="readout-row">
      <span class="r-tag">Decimal</span>
      <span class="r-val r-dec" data-out="dec">{initialPattern}</span>
    </div>
  </div>
</div>

<style>
  .led-scanner .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid theme('colors.ink.700');
  }
  .led-scanner .ctrl-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.rose.300');
    font-weight: 600;
  }
  .led-scanner .ctrl-hint {
    flex: 1;
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    color: theme('colors.ink.400');
  }
  .led-scanner .play-btn {
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    font-weight: 600;
    color: theme('colors.ink.200');
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 6px 12px;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .led-scanner .play-btn:hover {
    border-color: theme('colors.rose.400');
    color: theme('colors.rose.300');
  }

  .led-scanner .led-stage {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 1rem;
  }
  .led-scanner .led-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) 0.5rem repeat(4, minmax(0, 1fr));
    column-gap: 0.5rem;
    align-items: end;
    width: 100%;
    max-width: 32rem;
  }
  .led-scanner .nibble-spacer {
    width: 0.5rem;
  }
  .led-scanner .bit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 4px;
  }
  .led-scanner .bit-num {
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    color: theme('colors.ink.500');
    font-variant-numeric: tabular-nums;
  }
  .led-scanner .led-bezel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    padding: 3px;
    background: linear-gradient(145deg, theme('colors.ink.950'), theme('colors.ink.700'));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }
  .led-scanner .led {
    display: inline-block;
    border-radius: 3px;
    width: clamp(14px, 3.5cqi, 22px);
    height: clamp(48px, 11cqi, 72px);
    background: linear-gradient(180deg, #1a1d22 0%, #050608 60%, #000 100%);
    box-shadow:
      inset 0 0 6px rgba(0, 0, 0, 0.9),
      inset 0 1px 1px rgba(0, 0, 0, 0.8);
    transition: all 0.12s ease-out;
  }
  .led-scanner .bit[data-on='true'] .led {
    background: linear-gradient(180deg,
      color-mix(in srgb, theme('colors.rose.400') 70%, white) 0%,
      theme('colors.rose.400') 55%,
      theme('colors.rose.600') 100%);
    box-shadow:
      0 0 14px theme('colors.rose.400'),
      0 0 4px theme('colors.rose.400'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }
  .led-scanner .bit[data-on='true'] .bit-num {
    color: theme('colors.rose.300');
  }

  .led-scanner .readout {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid theme('colors.ink.700');
  }
  @container (max-width: 480px) {
    .led-scanner .readout {
      grid-template-columns: 1fr;
    }
  }
  .led-scanner .readout-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.95rem;
  }
  .led-scanner .r-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.400');
    font-weight: 600;
    min-width: 4.5rem;
  }
  .led-scanner .r-val { font-weight: 600; }
  .led-scanner .r-pos { color: theme('colors.ink.100'); }
  .led-scanner .r-bin { color: theme('colors.accent.DEFAULT'); }
  .led-scanner .r-hex { color: theme('colors.sky.300'); }
  .led-scanner .r-dec { color: theme('colors.amber.300'); }
</style>

<script>
  const wireLedScanner = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const speed = Number(root.dataset.speed ?? '90');
    const bitCells = Array.from(root.querySelectorAll<HTMLElement>('.bit[data-bit]'));
    const playBtn = root.querySelector<HTMLButtonElement>('[data-play]');
    const playLabel = root.querySelector<HTMLElement>('[data-play-label]');

    const out = {
      position: root.querySelector<HTMLElement>('[data-out="position"]'),
      bin: root.querySelector<HTMLElement>('[data-out="bin"]'),
      hex: root.querySelector<HTMLElement>('[data-out="hex"]'),
      dec: root.querySelector<HTMLElement>('[data-out="dec"]'),
    };

    const fmt2 = (v: number) => v.toString(16).toUpperCase().padStart(2, '0');
    const fmt8 = (v: number) => v.toString(2).padStart(8, '0');

    let position = 0;
    let direction = 1;
    let paused = false;

    const render = () => {
      const pattern = (1 << position) & 0xff;
      if (out.position) out.position.textContent = String(position);
      if (out.bin) out.bin.textContent = fmt8(pattern);
      if (out.hex) out.hex.textContent = fmt2(pattern);
      if (out.dec) out.dec.textContent = String(pattern);
      for (const cell of bitCells) {
        const i = Number(cell.dataset.bit);
        cell.dataset.on = ((pattern >> i) & 1) === 1 ? 'true' : 'false';
      }
    };

    const tick = () => {
      if (paused) return;
      position += direction;
      if (position >= 7) { position = 7; direction = -1; }
      else if (position <= 0) { position = 0; direction = 1; }
      render();
    };

    const updateButton = () => {
      if (playLabel) playLabel.textContent = paused ? '▶ Play' : '⏸ Pause';
    };

    playBtn?.addEventListener('click', () => {
      paused = !paused;
      updateButton();
    });

    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        (e.target as HTMLElement).dataset.visible = e.isIntersecting ? '1' : '0';
      }
    });
    obs.observe(root);

    window.setInterval(() => {
      if (root.dataset.visible === '0') return;
      tick();
    }, speed);

    render();
    updateButton();
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-led-scanner]').forEach(wireLedScanner);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
