---
interface Props {
  bits?: 8 | 16;
  start?: number;
  initialSpeed?: 'slow' | 'medium' | 'fast' | number;
  label?: string;
}

const {
  bits = 8,
  start = 0,
  initialSpeed = 'slow',
  label,
} = Astro.props;

const initialSliderValue =
  typeof initialSpeed === 'number'
    ? Math.max(0, Math.min(100, initialSpeed))
    : initialSpeed === 'slow'
      ? 15
      : initialSpeed === 'fast'
        ? 80
        : 50;

const indices = Array.from({ length: bits }, (_, i) => bits - 1 - i);
const power = (i: number) => 2 ** i;
const hexWidth = bits / 4;
const nibbleCount = bits / 4;
const nibbles: number[][] = [];
for (let n = 0; n < nibbleCount; n++) {
  nibbles.push(indices.slice(n * 4, (n + 1) * 4));
}
const initHex = start.toString(16).toUpperCase().padStart(hexWidth, '0');
const hexDigits = initHex.split('');
const gridTemplate =
  'auto ' +
  Array.from({ length: nibbleCount }, (_, n) =>
    (n > 0 ? '0.5rem ' : '') + 'repeat(4, minmax(0, 1fr))'
  ).join(' ');
---

<div
  class="bitcounter not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-bitcounter
  data-bits={bits}
  data-start={start}
  style="container-type: inline-size;"
>
  {label && <div class="text-mono-tag mb-3">{label}</div>}

  <div
    class="bitcounter-grid grid items-center gap-x-2 sm:gap-x-3 gap-y-1.5"
    style={`grid-template-columns: ${gridTemplate};`}
  >
    {/* BIT row */}
    <div class="row-label">Bit</div>
    {nibbles.map((nibble, n) => (
      <>
        {n > 0 && <div></div>}
        {nibble.map((i) => (
          <div class="font-mono text-xs sm:text-sm tabular-nums text-center text-ink-300">{i}</div>
        ))}
      </>
    ))}

    {/* LED row */}
    <div class="row-label">LED</div>
    {nibbles.map((nibble, n) => (
      <>
        {n > 0 && <div></div>}
        {nibble.map((i) => {
          const on = ((start >> i) & 1) === 1;
          return (
            <div
              class="bit flex items-center justify-center p-1.5"
              data-bit={i}
              data-on={on ? 'true' : 'false'}
            >
              <span class="led-bezel inline-flex items-center justify-center rounded-full">
                <span class="led inline-block rounded-full transition-all duration-100"></span>
              </span>
            </div>
          );
        })}
      </>
    ))}

    {/* VALUE row */}
    <div class="row-label">Bit value</div>
    {nibbles.map((nibble, n) => (
      <>
        {n > 0 && <div></div>}
        {nibble.map((i) => (
          <div class="font-mono text-xs sm:text-sm text-ink-200 tabular-nums text-center">{power(i)}</div>
        ))}
      </>
    ))}

    {/* BINARY group */}
    <div class="row-label format-label">Binary</div>
    <div class="format-card binary-card">
      {nibbles.map((nibble, n) => (
        <>
          {n > 0 && <div></div>}
          {nibble.map((i) => {
            const v = (start >> i) & 1;
            return (
              <div
                class="digit"
                data-digit-bit={i}
                data-on={v ? '1' : '0'}
              >{v}</div>
            );
          })}
        </>
      ))}
      <div class="prefix-line bin-prefix" style="grid-column: 1 / -1;">
        <span class="value-chip">%<span data-out="bin">{start.toString(2).padStart(bits, '0')}</span></span>
      </div>
    </div>

    {/* HEX group */}
    <div class="row-label format-label">Hex</div>
    <div class="format-card hex-card">
      {nibbles.map((nibble, n) => (
        <>
          {n > 0 && <div></div>}
          <div
            class="hex-cell"
            data-out-nibble={n}
            style="grid-column: span 4;"
          >{hexDigits[n]}</div>
        </>
      ))}
      <div class="prefix-line hex-prefix" style="grid-column: 1 / -1;">
        <span class="value-chip">$<span data-out="hex">{initHex}</span></span>
      </div>
    </div>

    {/* DECIMAL group */}
    <div class="row-label format-label">Decimal</div>
    <div class="format-card dec-card">
      <div class="dec-cell" style="grid-column: 1 / -1;"><span class="value-chip" data-out="dec">{start}</span></div>
    </div>
  </div>

  <div class="mt-5 pt-4 border-t border-ink-700 flex flex-wrap items-center gap-2">
    <button
      type="button"
      data-action="play"
      class="inline-flex items-center gap-2 rounded-md bg-accent text-ink-950 font-semibold px-3.5 py-1.5 text-sm hover:bg-accent-dim"
    >
      <span data-play-label>Play</span>
    </button>
    <button
      type="button"
      data-action="step-down"
      class="inline-flex items-center gap-2 rounded-md border border-ink-600 text-ink-200 px-3 py-1.5 text-sm hover:border-accent hover:text-accent"
    >
      Step −1
    </button>
    <button
      type="button"
      data-action="step"
      class="inline-flex items-center gap-2 rounded-md border border-ink-600 text-ink-200 px-3 py-1.5 text-sm hover:border-accent hover:text-accent"
    >
      Step +1
    </button>
    <button
      type="button"
      data-action="reset"
      class="inline-flex items-center gap-2 rounded-md border border-ink-600 text-ink-200 px-3 py-1.5 text-sm hover:border-accent hover:text-accent"
    >
      Reset
    </button>

    <label class="ml-auto flex items-center gap-2 select-none" aria-label="Counter speed">
      <span class="font-mono text-[10px] sm:text-xs uppercase tracking-[0.18em] text-ink-400 mr-1">Speed</span>
      <span aria-hidden="true" class="text-base sm:text-lg leading-none">🐢</span>
      <input
        type="range"
        data-speed-slider
        min="0"
        max="100"
        step="1"
        value={initialSliderValue}
        class="speed-slider w-24 sm:w-36"
        aria-label="Counter speed"
      />
      <span aria-hidden="true" class="text-base sm:text-lg leading-none">🐰</span>
    </label>
  </div>
</div>

<style>
  .bitcounter .row-label {
    font-family: theme('fontFamily.mono');
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.400');
    padding-right: 0.75rem;
    text-align: right;
  }
  @media (min-width: 640px) {
    .bitcounter .row-label { font-size: 12px; }
  }
  .bitcounter .format-card {
    grid-column: 2 / -1;
    display: grid;
    grid-template-columns: subgrid;
    align-items: center;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid theme('colors.ink.700');
    border-radius: 8px;
    padding: 0.5rem 0;
    margin-top: 0.5rem;
    row-gap: 0.5rem;
    column-gap: inherit;
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.6);
  }
  .bitcounter .format-label {
    align-self: center;
    margin-top: 0.5rem;
  }
  .bitcounter .prefix-line {
    grid-column: 1 / -1;
    text-align: center;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.95rem;
    padding: 0.125rem 0;
  }
  .bitcounter .bin-prefix { color: theme('colors.accent.DEFAULT'); }
  .bitcounter .hex-prefix { color: theme('colors.sky.300'); }
  .bitcounter .value-chip {
    display: inline-block;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 2px 10px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
  }

  .bitcounter .speed-slider {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    cursor: pointer;
    height: 1.25rem;
  }
  .bitcounter .speed-slider::-webkit-slider-runnable-track {
    height: 4px;
    background: theme('colors.ink.700');
    border-radius: 2px;
  }
  .bitcounter .speed-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: theme('colors.accent.DEFAULT');
    border-radius: 50%;
    margin-top: -5px;
    box-shadow: 0 0 6px theme('colors.accent.DEFAULT');
    cursor: grab;
  }
  .bitcounter .speed-slider::-webkit-slider-thumb:active {
    cursor: grabbing;
  }
  .bitcounter .speed-slider::-moz-range-track {
    height: 4px;
    background: theme('colors.ink.700');
    border-radius: 2px;
    border: none;
  }
  .bitcounter .speed-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: theme('colors.accent.DEFAULT');
    border-radius: 50%;
    border: none;
    box-shadow: 0 0 6px theme('colors.accent.DEFAULT');
    cursor: grab;
  }
  .bitcounter .speed-slider:focus-visible {
    outline: 2px solid theme('colors.accent.DEFAULT');
    outline-offset: 4px;
    border-radius: 2px;
  }

  .bitcounter[data-bits='8'] .led {
    width: clamp(16px, 4cqi, 36px);
    height: clamp(16px, 4cqi, 36px);
  }
  .bitcounter[data-bits='16'] .led {
    width: clamp(12px, 2.2cqi, 28px);
    height: clamp(12px, 2.2cqi, 28px);
  }
  .bitcounter .led-bezel {
    padding: 3px;
    background: linear-gradient(145deg, theme('colors.ink.950'), theme('colors.ink.700'));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }
  .bitcounter .led {
    background:
      radial-gradient(circle at 35% 30%, #1a1d22 0%, #050608 65%, #000 100%);
    box-shadow:
      inset 0 0 6px rgba(0, 0, 0, 0.9),
      inset 0 1px 1px rgba(0, 0, 0, 0.8);
  }
  .bitcounter .bit[data-on='true'] .led {
    background:
      radial-gradient(circle at 35% 30%,
        color-mix(in srgb, theme('colors.accent.DEFAULT') 80%, white) 0%,
        theme('colors.accent.DEFAULT') 55%,
        theme('colors.accent.dim') 100%);
    box-shadow:
      0 0 18px theme('colors.accent.DEFAULT'),
      0 0 4px theme('colors.accent.DEFAULT'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }

  .bitcounter .digit,
  .bitcounter .hex-cell,
  .bitcounter .dec-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 1rem;
    font-weight: 600;
    padding: 4px 0;
  }
  .bitcounter .digit {
    color: theme('colors.ink.500');
  }
  .bitcounter .digit[data-on='1'] {
    color: theme('colors.accent.DEFAULT');
  }
  .bitcounter .hex-cell {
    color: theme('colors.sky.300');
  }
  .bitcounter .dec-cell {
    color: theme('colors.amber.300');
  }

</style>

<script>
  const SLIDER_MIN_MS = 4;
  const SLIDER_MAX_MS = 1200;
  const sliderToSpeed = (v: number): number => {
    const t = Math.max(0, Math.min(100, v)) / 100;
    return Math.max(
      SLIDER_MIN_MS,
      Math.round(SLIDER_MAX_MS * Math.pow(SLIDER_MIN_MS / SLIDER_MAX_MS, t))
    );
  };

  const wireCounter = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const bits = Number(root.dataset.bits ?? '8');
    const start = Number(root.dataset.start ?? '0');
    const max = (1 << bits) - 1;
    const hexWidth = bits / 4;
    const nibbleCount = bits / 4;

    const decOut = root.querySelector<HTMLElement>('[data-out="dec"]');
    const decLineOut = root.querySelector<HTMLElement>('[data-out="dec-line"]');
    const hexLineOut = root.querySelector<HTMLElement>('[data-out="hex"]');
    const binLineOut = root.querySelector<HTMLElement>('[data-out="bin"]');
    const playBtn = root.querySelector<HTMLButtonElement>('[data-action="play"]');
    const playLabel = root.querySelector<HTMLElement>('[data-play-label]');
    const stepBtn = root.querySelector<HTMLButtonElement>('[data-action="step"]');
    const stepDownBtn = root.querySelector<HTMLButtonElement>('[data-action="step-down"]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-action="reset"]');
    const slider = root.querySelector<HTMLInputElement>('[data-speed-slider]');
    const bitCells = Array.from(root.querySelectorAll<HTMLElement>('.bit[data-bit]'));
    const digitCells = Array.from(root.querySelectorAll<HTMLElement>('[data-digit-bit]'));
    const hexCells = Array.from(root.querySelectorAll<HTMLElement>('[data-out-nibble]'));

    let value = start;
    let speed = sliderToSpeed(Number(slider?.value ?? '50'));
    let timer: number | null = null;

    const renderValue = () => {
      if (decOut) decOut.textContent = String(value);
      if (decLineOut) decLineOut.textContent = String(value);
      if (binLineOut) binLineOut.textContent = value.toString(2).padStart(bits, '0');
      if (hexLineOut) hexLineOut.textContent = value.toString(16).toUpperCase().padStart(hexWidth, '0');

      for (const cell of bitCells) {
        const idx = Number(cell.dataset.bit);
        cell.dataset.on = ((value >> idx) & 1) === 1 ? 'true' : 'false';
      }

      for (const cell of digitCells) {
        const idx = Number(cell.dataset.digitBit);
        const v = (value >> idx) & 1;
        const next = String(v);
        if (cell.textContent !== next) {
          cell.textContent = next;
          cell.dataset.on = next;
        }
      }

      for (const cell of hexCells) {
        const n = Number(cell.dataset.outNibble);
        const shift = (nibbleCount - 1 - n) * 4;
        const nibVal = (value >> shift) & 0xf;
        const next = nibVal.toString(16).toUpperCase();
        if (cell.textContent !== next) {
          cell.textContent = next;
        }
      }
    };

    const advance = () => {
      value = (value + 1) & max;
      renderValue();
    };

    const reverse = () => {
      value = (value - 1) & max;
      renderValue();
    };

    const stop = () => {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
      if (playLabel) playLabel.textContent = 'Play';
    };

    const start_ = () => {
      stop();
      timer = window.setInterval(advance, speed);
      if (playLabel) playLabel.textContent = 'Pause';
    };

    playBtn?.addEventListener('click', () => {
      if (timer !== null) stop();
      else start_();
    });

    stepBtn?.addEventListener('click', () => {
      stop();
      advance();
    });

    stepDownBtn?.addEventListener('click', () => {
      stop();
      reverse();
    });

    resetBtn?.addEventListener('click', () => {
      stop();
      value = start;
      renderValue();
    });

    slider?.addEventListener('input', () => {
      speed = sliderToSpeed(Number(slider.value));
      if (timer !== null) start_();
    });

    renderValue();
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-bitcounter]').forEach(wireCounter);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
