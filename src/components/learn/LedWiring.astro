---
interface Props {
  mode: 'active-high' | 'active-low';
  caption?: string;
}

const { mode, caption } = Astro.props;
const isHigh = mode === 'active-high';

// Layout is IDENTICAL between modes. The only differences:
//   - the right-end terminal (GND symbol vs +V rail)
//   - which side of the LED the cathode flat-mark sits on
//     (it always faces the direction current is leaving the LED)
const RESISTOR_X = 170;
const LED_X = 330;
---

<figure class="led-wiring learn-device not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner">
  <svg viewBox="-50 -10 620 155" xmlns="http://www.w3.org/2000/svg" class="wiring-svg" aria-hidden="true">
    {/* Horizontal wire from Pin (left) to the right terminal */}
    <line class="wire" x1="30" y1="55" x2="490" y2="55" />

    {/* Left endpoint — always the Pin */}
    <g class="terminal">
      <rect class="pin-box" x="6" y="38" width="48" height="34" rx="4" />
      <text class="terminal-label" x="30" y="59" text-anchor="middle">Pin</text>
      <text class="terminal-hint" x="30" y="92" text-anchor="middle">
        {isHigh ? '(sends 1 → on)' : '(sends 0 → on)'}
      </text>
    </g>

    {/* Resistor — always between Pin and LED */}
    <g class="resistor-group" transform={`translate(${RESISTOR_X}, 55)`}>
      <rect class="resistor-body" x="-32" y="-12" width="64" height="24" rx="3" />
      <text class="resistor-label" x="0" y="5" text-anchor="middle">R</text>
      <text class="component-tag" x="0" y="34" text-anchor="middle">resistor</text>
    </g>

    {/* LED — circle body, flat-mark on the cathode (current-exit) side */}
    <g class="led-group" transform={`translate(${LED_X}, 55)`}>
      {/* Glow ring (faint) */}
      <circle class="led-glow" cx="0" cy="0" r="20" />
      {/* Body */}
      <circle class="led-body" cx="0" cy="0" r="20" />
      {/* Cathode flat marker */}
      {isHigh ? (
        <>
          <line class="cathode-line" x1="17" y1="-15" x2="17" y2="15" />
          <text class="flat-label" x="40" y="-8" text-anchor="start">← flat side</text>
        </>
      ) : (
        <>
          <line class="cathode-line" x1="-17" y1="-15" x2="-17" y2="15" />
          <text class="flat-label" x="-40" y="-8" text-anchor="end">flat side →</text>
        </>
      )}
      <text class="component-tag" x="0" y="42" text-anchor="middle">LED</text>
    </g>

    {/* Right endpoint — GND for active-high, +V for active-low */}
    {isHigh ? (
      <g class="terminal" transform="translate(490, 55)">
        <line class="wire" x1="0" y1="0" x2="0" y2="12" />
        <line class="gnd-bar" x1="-15" y1="12" x2="15" y2="12" />
        <line class="gnd-bar" x1="-10" y1="20" x2="10" y2="20" />
        <line class="gnd-bar" x1="-5" y1="28" x2="5" y2="28" />
        <text class="terminal-label" x="0" y="48" text-anchor="middle">GND</text>
        <text class="terminal-hint" x="0" y="64" text-anchor="middle">(0 V — the floor)</text>
      </g>
    ) : (
      <g class="terminal" transform="translate(490, 55)">
        <line class="wire" x1="0" y1="0" x2="0" y2="-15" />
        <line class="rail-line" x1="-18" y1="-15" x2="18" y2="-15" />
        <text class="rail-label" x="0" y="-22" text-anchor="middle">+V</text>
        <text class="terminal-hint" x="0" y="32" text-anchor="middle">(always powered)</text>
      </g>
    )}
  </svg>

  {caption && <figcaption class="wiring-caption">{caption}</figcaption>}
</figure>

<style>
  .led-wiring .wiring-svg {
    display: block;
    width: 100%;
    max-width: 560px;
    height: auto;
    margin: 0 auto;
  }

  .led-wiring .wire,
  .led-wiring .gnd-bar,
  .led-wiring .rail-line {
    stroke: theme('colors.ink.300');
    stroke-width: 2;
    fill: none;
  }

  .led-wiring .pin-box {
    fill: theme('colors.ink.700');
    stroke: theme('colors.ink.400');
    stroke-width: 1;
  }
  .led-wiring .terminal-label {
    font-family: theme('fontFamily.mono');
    font-size: 14px;
    font-weight: 700;
    fill: theme('colors.ink.100');
  }
  .led-wiring .terminal-hint {
    font-family: theme('fontFamily.mono');
    font-size: 9px;
    letter-spacing: 0.05em;
    fill: theme('colors.ink.400');
  }
  .led-wiring .rail-label {
    font-family: theme('fontFamily.mono');
    font-size: 13px;
    font-weight: 700;
    fill: theme('colors.amber.300');
  }

  .led-wiring .resistor-body {
    fill: theme('colors.ink.900');
    stroke: theme('colors.amber.300');
    stroke-width: 1.5;
  }
  .led-wiring .resistor-label {
    font-family: theme('fontFamily.mono');
    font-size: 13px;
    font-weight: 700;
    fill: theme('colors.amber.300');
  }
  .led-wiring .component-tag {
    font-family: theme('fontFamily.mono');
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: theme('colors.ink.400');
    font-weight: 600;
  }

  .led-wiring .led-body {
    fill: theme('colors.accent.DEFAULT');
    stroke: color-mix(in srgb, theme('colors.accent.DEFAULT') 60%, white);
    stroke-width: 1.5;
    opacity: 0.85;
  }
  .led-wiring .led-glow {
    fill: none;
    stroke: theme('colors.accent.DEFAULT');
    stroke-width: 6;
    opacity: 0.25;
    filter: blur(2px);
  }
  .led-wiring .cathode-line {
    stroke: theme('colors.ink.100');
    stroke-width: 3;
  }
  .led-wiring .flat-label {
    font-family: theme('fontFamily.mono');
    font-size: 11px;
    font-weight: 600;
    fill: theme('colors.ink.200');
    paint-order: stroke fill;
    stroke: theme('colors.ink.800');
    stroke-width: 3.5;
    stroke-linejoin: round;
  }

  .led-wiring .wiring-caption {
    margin-top: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid theme('colors.ink.700');
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    color: theme('colors.ink.300');
    text-align: center;
  }
</style>
