---
interface Props {
  initial?: number;
  bits?: 8;
  label?: string;
}

const { initial = 1, bits = 8, label } = Astro.props;
const indices = Array.from({ length: bits }, (_, i) => bits - 1 - i);
const hexWidth = bits / 4;
const fmtBin = (v: number) => v.toString(2).padStart(bits, '0');
const fmtHex = (v: number) => v.toString(16).toUpperCase().padStart(hexWidth, '0');
---

<div
  class="bitshift learn-device not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-bitshift
  data-bits={bits}
  data-value={initial}
  style="container-type: inline-size;"
>
  {label && <div class="panel-title mb-4">{label}</div>}

  <div class="operand operand-bit">
    <div class="op-tag bit-row-tag">Bit</div>
    <div class="led-row">
      {indices.map((i, n) => (
        <>
          {n === 4 && <div></div>}
          <div class="bit-num">{i}</div>
        </>
      ))}
    </div>
    <div></div>
  </div>

  <div class="operand">
    <div class="op-tag">V</div>
    <div class="led-row">
      {indices.map((i, n) => (
        <>
          {n === 4 && <div></div>}
          <button
            type="button"
            class="bit"
            data-bit={i}
            data-on={((initial >> i) & 1) === 1 ? 'true' : 'false'}
            aria-pressed={((initial >> i) & 1) === 1 ? 'true' : 'false'}
            aria-label={`Bit ${i}, ${((initial >> i) & 1) === 1 ? 'on' : 'off'}`}
          >
            <span class="led-bezel">
              <span class="led"></span>
            </span>
          </button>
        </>
      ))}
    </div>
    <div class="readout">
      <span class="r-bin">%<span data-out="bin">{fmtBin(initial)}</span></span>
      <span class="r-hex">$<span data-out="hex">{fmtHex(initial)}</span></span>
      <span class="r-dec" data-out="dec">{initial}</span>
    </div>
  </div>

  <div class="shift-row">
    <div class="dropped-bit dropped-left" data-dropped="left">
      <span class="dropped-label">dropped</span>
      <span class="dropped-bit-cell" data-dropped-cell="left">·</span>
    </div>

    <div class="shift-buttons">
      <button type="button" data-action="shl" class="shift-btn">
        <span aria-hidden="true">«</span>
        <span>SHL ×2</span>
      </button>
      <button type="button" data-action="shr" class="shift-btn">
        <span>SHR ÷2</span>
        <span aria-hidden="true">»</span>
      </button>
      <button type="button" data-action="reset" class="reset-btn">Reset</button>
    </div>

    <div class="dropped-bit dropped-right" data-dropped="right">
      <span class="dropped-bit-cell" data-dropped-cell="right">·</span>
      <span class="dropped-label">dropped</span>
    </div>
  </div>
</div>

<style>
  .bitshift .operand {
    display: grid;
    grid-template-columns: 2rem 1fr minmax(6rem, auto);
    align-items: center;
    column-gap: 0.75rem;
  }
  .bitshift .op-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.95rem;
    font-weight: 700;
    color: theme('colors.ink.300');
    text-align: center;
  }
  .bitshift .bit-row-tag {
    color: theme('colors.ink.400');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
  }
  .bitshift .bit-num {
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.8rem;
    color: theme('colors.ink.400');
    text-align: center;
  }
  .bitshift .operand-bit {
    margin-bottom: 0.25rem;
  }
  .bitshift .led-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) 0.5rem repeat(4, minmax(0, 1fr));
    align-items: center;
    column-gap: 0.5rem;
  }
  .bitshift .bit {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border-radius: 6px;
    cursor: pointer;
    border: none;
    background: transparent;
  }
  .bitshift .bit:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .bitshift .led-bezel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 3px;
    background: linear-gradient(145deg, theme('colors.ink.950'), theme('colors.ink.700'));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }
  .bitshift .led {
    display: inline-block;
    border-radius: 999px;
    width: clamp(14px, 3.5cqi, 30px);
    height: clamp(14px, 3.5cqi, 30px);
    background: radial-gradient(circle at 35% 30%, #1a1d22 0%, #050608 65%, #000 100%);
    box-shadow:
      inset 0 0 6px rgba(0, 0, 0, 0.9),
      inset 0 1px 1px rgba(0, 0, 0, 0.8);
    transition: all 0.15s;
  }
  .bitshift .bit[data-on='true'] .led {
    background: radial-gradient(
      circle at 35% 30%,
      color-mix(in srgb, theme('colors.accent.DEFAULT') 80%, white) 0%,
      theme('colors.accent.DEFAULT') 55%,
      theme('colors.accent.dim') 100%);
    box-shadow:
      0 0 14px theme('colors.accent.DEFAULT'),
      0 0 4px theme('colors.accent.DEFAULT'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }

  .bitshift .readout {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.85rem;
    line-height: 1.3;
    gap: 1px;
    min-width: 6rem;
  }
  .bitshift .r-bin { color: theme('colors.accent.DEFAULT'); }
  .bitshift .r-hex { color: theme('colors.sky.300'); }
  .bitshift .r-dec { color: theme('colors.amber.300'); font-weight: 600; }

  .bitshift .shift-row {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid theme('colors.ink.700');
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .bitshift .shift-buttons {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .bitshift .shift-btn {
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    color: theme('colors.ink.200');
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 6px 12px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .bitshift .shift-btn:hover {
    border-color: theme('colors.accent.DEFAULT');
    color: theme('colors.accent.DEFAULT');
  }
  .bitshift .reset-btn {
    font-family: theme('fontFamily.mono');
    font-size: 0.8rem;
    color: theme('colors.ink.300');
    background: transparent;
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
  }
  .bitshift .reset-btn:hover {
    border-color: theme('colors.ink.500');
    color: theme('colors.ink.100');
  }

  .bitshift .dropped-bit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.500');
  }
  .bitshift .dropped-left { justify-content: flex-end; }
  .bitshift .dropped-right { justify-content: flex-start; }
  .bitshift .dropped-bit-cell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: theme('colors.ink.500');
    font-size: 0.95rem;
    font-weight: 600;
  }
  .bitshift .dropped-bit-cell[data-bit='1'] {
    color: theme('colors.rose.300');
    background: rgba(244, 63, 94, 0.12);
    border-color: rgba(244, 63, 94, 0.4);
  }
</style>

<script>
  const wireBitShift = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const bits = Number(root.dataset.bits ?? '8');
    const initial = Number(root.dataset.value ?? '0');
    const mask = (1 << bits) - 1;
    const hexWidth = bits / 4;

    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-bit]'));
    const binOut = root.querySelector<HTMLElement>('[data-out="bin"]');
    const hexOut = root.querySelector<HTMLElement>('[data-out="hex"]');
    const decOut = root.querySelector<HTMLElement>('[data-out="dec"]');
    const droppedLeft = root.querySelector<HTMLElement>('[data-dropped-cell="left"]');
    const droppedRight = root.querySelector<HTMLElement>('[data-dropped-cell="right"]');
    const shlBtn = root.querySelector<HTMLButtonElement>('[data-action="shl"]');
    const shrBtn = root.querySelector<HTMLButtonElement>('[data-action="shr"]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-action="reset"]');

    let value = initial;

    const renderBits = () => {
      for (const btn of buttons) {
        const i = Number(btn.dataset.bit);
        const on = ((value >> i) & 1) === 1;
        btn.dataset.on = on ? 'true' : 'false';
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        btn.setAttribute('aria-label', `Bit ${i}, ${on ? 'on' : 'off'}`);
      }
      if (binOut) binOut.textContent = value.toString(2).padStart(bits, '0');
      if (hexOut) hexOut.textContent = value.toString(16).toUpperCase().padStart(hexWidth, '0');
      if (decOut) decOut.textContent = String(value);
    };

    const setDropped = (side: 'left' | 'right', bit: number | null) => {
      const cell = side === 'left' ? droppedLeft : droppedRight;
      const other = side === 'left' ? droppedRight : droppedLeft;
      if (cell) {
        if (bit === null) {
          cell.textContent = '·';
          delete cell.dataset.bit;
        } else {
          cell.textContent = String(bit);
          cell.dataset.bit = String(bit);
        }
      }
      if (other) {
        other.textContent = '·';
        delete other.dataset.bit;
      }
    };

    for (const btn of buttons) {
      btn.addEventListener('click', () => {
        const i = Number(btn.dataset.bit);
        value ^= (1 << i);
        value &= mask;
        renderBits();
      });
    }

    shlBtn?.addEventListener('click', () => {
      const out = (value >> (bits - 1)) & 1;
      value = (value << 1) & mask;
      renderBits();
      setDropped('left', out);
    });

    shrBtn?.addEventListener('click', () => {
      const out = value & 1;
      value = (value >> 1) & mask;
      renderBits();
      setDropped('right', out);
    });

    resetBtn?.addEventListener('click', () => {
      value = initial;
      renderBits();
      setDropped('left', null);
    });

    renderBits();
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-bitshift]').forEach(wireBitShift);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
