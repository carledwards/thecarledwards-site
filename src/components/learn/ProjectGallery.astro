---
interface Project {
  title: string;
  description: string;
  image: string;
  href: string;
  platform?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="project-gallery not-prose my-6">
  <div class="gallery-grid">
    {projects.map((p) => (
      <a class="gallery-card" href={p.href} target="_blank" rel="noopener noreferrer">
        <div class="card-image">
          <img src={p.image} alt={p.title} loading="lazy" />
        </div>
        <div class="card-body">
          {p.platform && <div class="card-platform">{p.platform}</div>}
          <h3 class="card-title">{p.title}</h3>
          <p class="card-desc">{p.description}</p>
          <div class="card-link">View on GitHub →</div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .project-gallery .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .project-gallery .gallery-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: theme('colors.ink.900');
    border: 1px solid theme('colors.ink.700');
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .project-gallery .gallery-card:hover {
    border-color: theme('colors.accent.DEFAULT');
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.6);
  }

  .project-gallery .card-image {
    aspect-ratio: 16 / 10;
    background: theme('colors.ink.950');
    border-bottom: 1px solid theme('colors.ink.800');
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem;
  }
  .project-gallery .card-image img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    transition: transform 0.25s;
  }
  .project-gallery .gallery-card:hover .card-image img {
    transform: scale(1.02);
  }

  .project-gallery .card-body {
    padding: 0.85rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .project-gallery .card-platform {
    font-family: theme('fontFamily.mono');
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.accent.DEFAULT');
    font-weight: 600;
  }
  .project-gallery .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: theme('colors.ink.100');
    margin: 0;
    line-height: 1.3;
  }
  .project-gallery .card-desc {
    flex: 1;
    font-size: 0.85rem;
    color: theme('colors.ink.300');
    line-height: 1.5;
    margin: 0;
  }
  .project-gallery .card-link {
    margin-top: 0.4rem;
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: theme('colors.ink.400');
    transition: color 0.2s;
  }
  .project-gallery .gallery-card:hover .card-link {
    color: theme('colors.accent.DEFAULT');
  }
</style>
