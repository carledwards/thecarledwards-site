---
type Op = 'AND' | 'OR' | 'XOR' | 'NOT' | 'ADD' | 'SUB';

interface Props {
  initialA?: number;
  initialB?: number;
  op?: Op;
  label?: string;
  bits?: 8;
  lockOp?: boolean;
}

const {
  initialA = 0,
  initialB = 0,
  op = 'AND',
  label,
  bits = 8,
  lockOp = false,
} = Astro.props;

const indices = Array.from({ length: bits }, (_, i) => bits - 1 - i);
const hexWidth = bits / 4;
const mask = (1 << bits) - 1;
const compute = (a: number, b: number, o: Op): { result: number; carry: boolean } => {
  switch (o) {
    case 'AND': return { result: (a & b) & mask, carry: false };
    case 'OR':  return { result: (a | b) & mask, carry: false };
    case 'XOR': return { result: (a ^ b) & mask, carry: false };
    case 'NOT': return { result: (~a) & mask, carry: false };
    case 'ADD': {
      const sum = a + b;
      return { result: sum & mask, carry: sum > mask };
    }
    case 'SUB': {
      const diff = a - b;
      return { result: diff & mask, carry: diff < 0 };
    }
  }
};
const initialComp = compute(initialA, initialB, op);
const initialResult = initialComp.result;
const initialCarry = initialComp.carry;
const fmtBin = (v: number) => v.toString(2).padStart(bits, '0');
const fmtHex = (v: number) => v.toString(16).toUpperCase().padStart(hexWidth, '0');
const ops: Op[] = ['AND', 'OR', 'XOR', 'NOT', 'ADD', 'SUB'];

// column for bit at display index n (0-based, 0 = leftmost = MSB)
const colFor = (n: number) => (n < 4 ? n + 2 : n + 3);
---

<div
  class="bitop not-prose my-6 rounded-lg border border-ink-700 bg-ink-800 p-5 shadow-inner"
  data-bitop
  data-bits={bits}
  data-op={op}
  style="container-type: inline-size;"
>
  {label && <div class="panel-title mb-4">{label}</div>}

  <div class="bitop-content">
  <div class="bit-rails-overlay" aria-hidden="true">
    <div></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div class="rail"></div>
    <div></div>
  </div>
  <div class="bitop-grid">
    {/* BIT row */}
    <div class="op-tag bit-row-tag">Bit</div>
    {indices.map((i, n) => (
      <>
        {n === 4 && <div></div>}
        <div class="bit-num">{i}</div>
      </>
    ))}
    <div></div>

    {/* A row */}
    <div class="op-tag" data-row="a">A</div>
    {indices.map((i, n) => (
      <>
        {n === 4 && <div data-row="a"></div>}
        <button
          type="button"
          class="bit"
          data-operand="a"
          data-bit={i}
          data-on={((initialA >> i) & 1) === 1 ? 'true' : 'false'}
          aria-pressed={((initialA >> i) & 1) === 1 ? 'true' : 'false'}
          aria-label={`A bit ${i}, ${((initialA >> i) & 1) === 1 ? 'on' : 'off'}`}
        >
          <span class="led-bezel">
            <span class="led"></span>
          </span>
        </button>
      </>
    ))}
    <div class="readout" data-row="a">
      <span class="r-bin">%<span data-out="a-bin">{fmtBin(initialA)}</span></span>
      <span class="r-hex">$<span data-out="a-hex">{fmtHex(initialA)}</span></span>
      <span class="r-dec" data-out="a-dec">{initialA}</span>
    </div>

    {/* Op selector */}
    <div class="op-selector" role="group" aria-label="Operation" style="grid-column: 1 / -1;">
      {ops.map((o) => (
        <button
          type="button"
          class="op-pill"
          data-op-set={o}
          data-active={o === op ? 'true' : 'false'}
          disabled={lockOp && o !== op}
        >
          {o}
        </button>
      ))}
    </div>

    {/* B row (hidden when NOT) */}
    <div class="op-tag" data-row="b">B</div>
    {indices.map((i, n) => (
      <>
        {n === 4 && <div data-row="b"></div>}
        <button
          type="button"
          class="bit"
          data-operand="b"
          data-bit={i}
          data-on={((initialB >> i) & 1) === 1 ? 'true' : 'false'}
          aria-pressed={((initialB >> i) & 1) === 1 ? 'true' : 'false'}
          aria-label={`B bit ${i}, ${((initialB >> i) & 1) === 1 ? 'on' : 'off'}`}
        >
          <span class="led-bezel">
            <span class="led"></span>
          </span>
        </button>
      </>
    ))}
    <div class="readout" data-row="b">
      <span class="r-bin">%<span data-out="b-bin">{fmtBin(initialB)}</span></span>
      <span class="r-hex">$<span data-out="b-hex">{fmtHex(initialB)}</span></span>
      <span class="r-dec" data-out="b-dec">{initialB}</span>
    </div>

    {/* Divider */}
    <div class="op-divider" style="grid-column: 1 / -1;"></div>

    {/* Result row */}
    <div class="op-tag op-tag-eq">=</div>
    {indices.map((i, n) => (
      <>
        {n === 4 && <div></div>}
        <div
          class="bit"
          data-result-bit={i}
          data-on={((initialResult >> i) & 1) === 1 ? 'true' : 'false'}
        >
          <span class="led-bezel">
            <span class="led"></span>
          </span>
        </div>
      </>
    ))}
    <div class="readout">
      <span class="r-bin">%<span data-out="r-bin">{fmtBin(initialResult)}</span></span>
      <span class="r-hex">$<span data-out="r-hex">{fmtHex(initialResult)}</span></span>
      <span class="r-dec" data-out="r-dec">{initialResult}</span>
    </div>

  </div>
  </div>

  <div class="carry-flag" data-carry-flag data-active={initialCarry ? 'true' : 'false'}>
    <span class="carry-label">Carry</span>
    <span class="carry-dot"></span>
  </div>
</div>

<style>
  .bitop .bitop-grid {
    display: grid;
    grid-template-columns: 2rem repeat(4, minmax(0, 1fr)) 0.5rem repeat(4, minmax(0, 1fr)) minmax(6rem, auto);
    align-items: center;
    column-gap: 0.5rem;
    row-gap: 0.4rem;
  }

  .bitop .op-tag {
    font-family: theme('fontFamily.mono');
    font-size: 0.95rem;
    font-weight: 700;
    color: theme('colors.ink.300');
    text-align: center;
    z-index: 1;
  }
  .bitop .op-tag-eq {
    color: theme('colors.accent.DEFAULT');
    font-size: 1.1rem;
  }
  .bitop .bit-row-tag {
    color: theme('colors.ink.400');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .bitop .bit-num {
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.8rem;
    color: theme('colors.ink.400');
    text-align: center;
    z-index: 1;
    position: relative;
  }

  .bitop[data-op='NOT'] [data-row='b'] {
    display: none;
  }

  .bitop .bit {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border-radius: 6px;
    cursor: pointer;
    border: none;
    background: transparent;
    z-index: 1;
    position: relative;
  }
  .bitop .bit:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .bitop > .bitop-grid > .bit[data-result-bit] {
    cursor: default;
  }
  .bitop > .bitop-grid > .bit[data-result-bit]:hover {
    background: transparent;
  }

  .bitop .led-bezel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 3px;
    background: linear-gradient(145deg, theme('colors.ink.950'), theme('colors.ink.700'));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }
  .bitop .led {
    display: inline-block;
    border-radius: 999px;
    width: clamp(14px, 3.5cqi, 30px);
    height: clamp(14px, 3.5cqi, 30px);
    background: radial-gradient(circle at 35% 30%, #1a1d22 0%, #050608 65%, #000 100%);
    box-shadow:
      inset 0 0 6px rgba(0, 0, 0, 0.9),
      inset 0 1px 1px rgba(0, 0, 0, 0.8);
    transition: all 0.1s;
  }
  .bitop .bit[data-on='true'] .led {
    background: radial-gradient(
      circle at 35% 30%,
      color-mix(in srgb, theme('colors.accent.DEFAULT') 80%, white) 0%,
      theme('colors.accent.DEFAULT') 55%,
      theme('colors.accent.dim') 100%);
    box-shadow:
      0 0 14px theme('colors.accent.DEFAULT'),
      0 0 4px theme('colors.accent.DEFAULT'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }
  .bitop .bit[data-result-bit][data-on='true'] .led {
    background: radial-gradient(
      circle at 35% 30%,
      color-mix(in srgb, theme('colors.amber.300') 80%, white) 0%,
      theme('colors.amber.300') 55%,
      theme('colors.amber.500') 100%);
    box-shadow:
      0 0 14px theme('colors.amber.300'),
      0 0 4px theme('colors.amber.300'),
      inset 0 0 6px rgba(255, 255, 255, 0.4);
  }

  .bitop .readout {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: theme('fontFamily.mono');
    font-variant-numeric: tabular-nums;
    font-size: 0.85rem;
    line-height: 1.3;
    gap: 1px;
    z-index: 1;
    position: relative;
    background: theme('colors.ink.800');
    padding-left: 0.5rem;
  }
  .bitop .r-bin { color: theme('colors.accent.DEFAULT'); }
  .bitop .r-hex { color: theme('colors.sky.300'); }
  .bitop .r-dec { color: theme('colors.amber.300'); font-weight: 600; }

  .bitop .op-selector {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin: 0.4rem 0;
    z-index: 1;
    position: relative;
  }
  .bitop .op-pill {
    font-family: theme('fontFamily.mono');
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: theme('colors.ink.300');
    background: theme('colors.ink.800');
    border: 1px solid theme('colors.ink.700');
    border-radius: 6px;
    padding: 4px 12px;
    cursor: pointer;
    transition: border-color 0.1s, color 0.1s;
  }
  .bitop .op-pill:hover:not(:disabled) {
    border-color: theme('colors.accent.DEFAULT');
    color: theme('colors.accent.DEFAULT');
  }
  .bitop .op-pill[data-active='true'] {
    border-color: theme('colors.accent.DEFAULT');
    background: theme('colors.accent.DEFAULT');
    color: theme('colors.ink.950');
  }
  .bitop .op-pill:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .bitop .op-divider {
    height: 1px;
    background: theme('colors.ink.700');
    margin: 0.4rem 0;
    z-index: 1;
    position: relative;
  }

  /* Vertical column rails — overlay aligned to the same grid template */
  .bitop .bitop-content {
    position: relative;
  }
  .bitop .bit-rails-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 2rem repeat(4, minmax(0, 1fr)) 0.5rem repeat(4, minmax(0, 1fr)) minmax(6rem, auto);
    column-gap: 0.5rem;
    pointer-events: none;
    z-index: 0;
  }
  .bitop .bit-rails-overlay .rail {
    width: 1px;
    background: rgba(255, 255, 255, 0.05);
    justify-self: center;
    height: 100%;
  }
  .bitop .bitop-grid {
    position: relative;
    z-index: 1;
  }

  .bitop .carry-flag {
    display: none;
    align-items: center;
    gap: 6px;
    margin: 0.5rem 0 0;
    padding-left: calc(2rem + 0.5rem);
    font-family: theme('fontFamily.mono');
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme('colors.ink.500');
  }
  .bitop[data-op='ADD'] .carry-flag,
  .bitop[data-op='SUB'] .carry-flag {
    display: flex;
  }
  .bitop .carry-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: theme('colors.ink.700');
    border: 1px solid theme('colors.ink.600');
  }
  .bitop .carry-flag[data-active='true'] .carry-dot {
    background: theme('colors.rose.400');
    border-color: theme('colors.rose.300');
    box-shadow: 0 0 8px theme('colors.rose.400');
  }
  .bitop .carry-flag[data-active='true'] {
    color: theme('colors.rose.300');
  }
</style>

<script>
  type Op = 'AND' | 'OR' | 'XOR' | 'NOT' | 'ADD' | 'SUB';

  const wireBitOp = (root: HTMLElement) => {
    if (root.dataset.wired === '1') return;
    root.dataset.wired = '1';

    const bits = Number(root.dataset.bits ?? '8');
    const hexWidth = bits / 4;
    const mask = (1 << bits) - 1;

    const aBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-operand="a"]'));
    const bBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-operand="b"]'));
    const rCells = Array.from(root.querySelectorAll<HTMLElement>('[data-result-bit]'));
    const opPills = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-op-set]'));

    const out = (key: string) => root.querySelector<HTMLElement>(`[data-out="${key}"]`);
    const aBin = out('a-bin'), aHex = out('a-hex'), aDec = out('a-dec');
    const bBin = out('b-bin'), bHex = out('b-hex'), bDec = out('b-dec');
    const rBin = out('r-bin'), rHex = out('r-hex'), rDec = out('r-dec');

    const readValue = (btns: HTMLButtonElement[]): number => {
      let v = 0;
      for (const b of btns) {
        if (b.dataset.on === 'true') v |= 1 << Number(b.dataset.bit);
      }
      return v;
    };

    const compute = (a: number, b: number, op: Op): { result: number; carry: boolean } => {
      switch (op) {
        case 'AND': return { result: (a & b) & mask, carry: false };
        case 'OR':  return { result: (a | b) & mask, carry: false };
        case 'XOR': return { result: (a ^ b) & mask, carry: false };
        case 'NOT': return { result: (~a) & mask, carry: false };
        case 'ADD': {
          const sum = a + b;
          return { result: sum & mask, carry: sum > mask };
        }
        case 'SUB': {
          const diff = a - b;
          return { result: diff & mask, carry: diff < 0 };
        }
      }
    };

    const setBtnAria = (btn: HTMLButtonElement, on: boolean) => {
      btn.dataset.on = on ? 'true' : 'false';
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      const operand = btn.dataset.operand?.toUpperCase() ?? '?';
      const idx = btn.dataset.bit ?? '?';
      btn.setAttribute('aria-label', `${operand} bit ${idx}, ${on ? 'on' : 'off'}`);
    };

    const writeText = (el: HTMLElement | null, s: string) => {
      if (el && el.textContent !== s) el.textContent = s;
    };

    const carryFlag = root.querySelector<HTMLElement>('[data-carry-flag]');

    const render = () => {
      const a = readValue(aBtns);
      const b = readValue(bBtns);
      const op = (root.dataset.op ?? 'AND') as Op;
      const { result: r, carry } = compute(a, b, op);

      writeText(aBin, a.toString(2).padStart(bits, '0'));
      writeText(aHex, a.toString(16).toUpperCase().padStart(hexWidth, '0'));
      writeText(aDec, String(a));
      writeText(bBin, b.toString(2).padStart(bits, '0'));
      writeText(bHex, b.toString(16).toUpperCase().padStart(hexWidth, '0'));
      writeText(bDec, String(b));
      writeText(rBin, r.toString(2).padStart(bits, '0'));
      writeText(rHex, r.toString(16).toUpperCase().padStart(hexWidth, '0'));
      writeText(rDec, String(r));

      for (const cell of rCells) {
        const i = Number(cell.dataset.resultBit);
        cell.dataset.on = ((r >> i) & 1) === 1 ? 'true' : 'false';
      }

      if (carryFlag) {
        carryFlag.dataset.active = carry ? 'true' : 'false';
        const labelEl = carryFlag.querySelector<HTMLElement>('.carry-label');
        if (labelEl) {
          labelEl.textContent = op === 'SUB' ? 'Borrow' : 'Carry';
        }
      }
    };

    for (const btn of [...aBtns, ...bBtns]) {
      btn.addEventListener('click', () => {
        setBtnAria(btn, btn.dataset.on !== 'true');
        render();
      });
    }

    for (const pill of opPills) {
      if (pill.disabled) continue;
      pill.addEventListener('click', () => {
        const next = (pill.dataset.opSet ?? 'AND') as Op;
        root.dataset.op = next;
        for (const p of opPills) {
          p.dataset.active = p.dataset.opSet === next ? 'true' : 'false';
        }
        render();
      });
    }

    render();
  };

  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-bitop]').forEach(wireBitOp);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
