---
// FoxproOverlay — a full-viewport canvas that mounts a foxpro-go WASM
// "FoxPro Mode" on top of the page on demand.
//
// Render this once in BaseLayout.astro. The wasm is loaded lazily on
// first activation, then kept resident so subsequent toggles are instant.
//
// Talks to the wasm through window.foxproWasm (set by foxpro-go's
// browser bridge). The wasm talks back via window.siteAPI, defined in
// the inline script below — that's where Go-side menu items reach
// browser features (open URL, navigate, close overlay).
---

<button
  id="foxpro-toggle"
  type="button"
  aria-label="Toggle Retro FoxPro Mode"
  class="fixed bottom-4 right-4 z-40 overflow-hidden rounded-md border border-ink-700 bg-ink-900/90 px-3 py-2 font-mono text-xs text-ink-200 shadow-lg backdrop-blur transition hover:border-accent hover:text-accent"
>
  <span class="relative z-10">▣ Retro FoxPro Mode</span>
  <span class="foxpro-shimmer" aria-hidden="true"></span>
</button>

<style is:global>
  /* Sweep highlight that travels across the FoxPro Mode button every
     few seconds. Pulled to the side most of the cycle (translateX
     keyframes spend ~70% off-screen) so it reads as a periodic glint
     rather than a constant glow. Disabled for users who prefer
     reduced motion. */
  @keyframes foxpro-sheen {
    0%, 70% {
      transform: translateX(-110%);
    }
    100% {
      transform: translateX(220%);
    }
  }
  #foxpro-toggle .foxpro-shimmer {
    position: absolute;
    inset: 0;
    width: 50%;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(255, 255, 255, 0.22) 50%,
      transparent 100%
    );
    transform: translateX(-110%);
    animation: foxpro-sheen 4.5s ease-in-out infinite;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #foxpro-toggle .foxpro-shimmer {
      animation: none;
    }
  }
</style>

<div
  id="foxpro-overlay"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink-950/70 p-6 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="FoxPro Mode"
>
  <div class="relative">
    <button
      id="foxpro-close"
      type="button"
      aria-label="Close FoxPro Mode"
      class="absolute -top-3.5 -right-3.5 z-10 flex h-7 w-7 items-center justify-center rounded-full border border-ink-700 bg-ink-900/90 text-ink-200 hover:border-accent hover:text-accent hover:bg-ink-800 font-mono text-xs shadow-lg transition-colors"
    >
      ✕
    </button>
    <canvas
      id="foxpro-screen"
      tabindex="0"
      class="block max-h-[calc(100vh-3rem)] max-w-[calc(100vw-3rem)] rounded-md outline-none ring-1 ring-ink-700/60"
      style="image-rendering: pixelated; background:#0000aa; box-shadow: 0 30px 80px -20px rgba(0,0,0,0.8), 0 10px 30px -8px rgba(0,0,0,0.6);"
    ></canvas>
  </div>
</div>

<!-- DOS reboot overlay. Stacks above #foxpro-overlay (z-60 vs z-50)
     so the simulated BIOS-POST → DOS → FoxPro splash sequence covers
     everything during a Reboot. Hidden by default; shown only while
     siteAPI.reboot() is running. -->
<div
  id="foxpro-boot"
  class="fixed inset-0 z-[60] hidden bg-black"
  aria-hidden="true"
>
  <pre
    id="foxpro-boot-output"
    class="m-0 px-4 py-3 text-[14px] leading-tight font-mono text-[#cccccc] whitespace-pre-wrap"
    style="text-shadow: 0 0 1px rgba(204,204,204,0.5);"
  ></pre>
  <div
    id="foxpro-boot-splash"
    class="hidden absolute inset-0 flex items-center justify-center"
  >
    <pre class="m-0 font-mono text-[#ffffff] bg-[#0000aa] px-6 py-4 text-[16px] leading-tight border-4 border-[#aaaaaa]">
   Microsoft  FoxPro  for  DOS

         Version 2.6

   (C) Copyright Microsoft Corp.
            1989-1995

   Loading...
    </pre>
  </div>
</div>

<script is:inline src="/foxpro/wasm_exec.js"></script>
<script is:inline src="/foxpro/foxpro.js"></script>
<script is:inline>
  // siteAPI — the seam Go talks through. Defined before the wasm
  // boots so js.Global().Get("siteAPI").Call(...) inside the wasm
  // always finds these.
  window.siteAPI = {
    openURL: (url) =>
      window.open(url, '_blank', 'noopener,noreferrer'),
    navigate: (path) => window.location.assign(path),
    close: () => window.foxproOverlay && window.foxproOverlay.close(),
    reboot: () => fakeReboot(),
  };

  // fakeReboot — runs a tongue-in-cheek BIOS POST → DOS → FoxPro
  // splash sequence on a black overlay, then reloads the page so
  // the wasm comes up fresh (Go-side cleared localStorage already).
  // Pure cosmetic: nothing actually crashes or restarts; the page
  // reload at the end is what gives the user a clean slate.
  async function fakeReboot() {
    const bootEl = document.getElementById('foxpro-boot');
    const outEl = document.getElementById('foxpro-boot-output');
    const splashEl = document.getElementById('foxpro-boot-splash');
    const overlayEl = document.getElementById('foxpro-overlay');
    if (!bootEl || !outEl) {
      window.location.reload();
      return;
    }

    // Hide foxpro overlay if it's open; show the boot terminal.
    overlayEl.classList.add('hidden');
    overlayEl.classList.remove('flex');
    splashEl.classList.add('hidden');
    outEl.textContent = '';
    bootEl.classList.remove('hidden');

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    // Stage 1 — BIOS POST. Each line scrolls in with a tiny delay
    // so the eye registers the sequence, with longer pauses on
    // realistic-feeling moments (memory test, drive detection).
    const lines = [
      ['AMIBIOS (C)1995 American Megatrends, Inc.', 80],
      ['BIOS Date: 04/15/95   v2.6.1   Rev: 1.0', 60],
      ['', 60],
      ['Pentium-S CPU  at 100MHz', 60],
      ['Memory Test :    640 KB OK', 220],
      ['Memory Test :  16384 KB OK', 220],
      ['', 100],
      ['Press DEL to enter SETUP', 80],
      ['', 100],
      ['Detecting Primary Master  ... ST31010A 1.0GB', 320],
      ['Detecting Primary Slave   ... None', 200],
      ['Detecting Secondary Master ... CD-ROM TOSHIBA', 260],
      ['Detecting Secondary Slave ... None', 180],
      ['', 120],
      ['Verifying DMI Pool Data....................', 250],
      ['', 200],
      // Stage 2 — DOS boot
      ['Starting MS-DOS...', 600],
      ['', 80],
      ['HIMEM is testing extended memory...done.', 220],
      ['EMM386 successfully installed.', 120],
      ['Microsoft Mouse Driver V9.01 installed.', 120],
      ['SMARTDrv: Cache size 2,048 KB in extended memory.', 140],
      ['', 200],
      // Stage 3 — autoexec lands the user at FoxPro
      ['C:\\>cd \\FOXPRO', 280],
      ['', 80],
      ['C:\\FOXPRO>fox', 350],
      ['', 250],
    ];
    for (const [text, wait] of lines) {
      outEl.textContent += text + '\n';
      bootEl.scrollTop = bootEl.scrollHeight;
      await sleep(wait);
    }

    // Stage 4 — FoxPro splash overlays the terminal for a moment.
    splashEl.classList.remove('hidden');
    splashEl.classList.add('flex');
    await sleep(1400);

    // Stage 5 — full reload. localStorage was cleared by Go
    // before this fired, so the next boot starts on the default
    // theme. sessionStorage tells the freshly-loaded page to
    // auto-open the overlay so the user lands directly back
    // inside FoxPro Mode instead of staring at the homepage.
    try {
      sessionStorage.setItem('foxpro.autoOpen', '1');
    } catch (e) {
      /* private-mode etc. — fall back to a normal reload */
    }
    window.location.reload();
  }

  // If a Reboot just finished (sessionStorage flag set before the
  // reload), pop the overlay open as soon as we're loaded.
  try {
    if (sessionStorage.getItem('foxpro.autoOpen') === '1') {
      sessionStorage.removeItem('foxpro.autoOpen');
      // Defer one tick so the toggle's open() handler — defined
      // a few lines below in the same script — has finished
      // attaching window.foxproOverlay.
      setTimeout(() => {
        if (window.foxproOverlay) window.foxproOverlay.open();
      }, 0);
    }
  } catch (e) {
    /* ignore — sessionStorage unavailable */
  }

  (() => {
    // Lazy-load wasm on first overlay open. Once booted it stays
    // resident so subsequent toggles are instant.
    const toggle = document.getElementById('foxpro-toggle');
    const overlay = document.getElementById('foxpro-overlay');
    const canvas = document.getElementById('foxpro-screen');

    let bootStarted = false;
    function open() {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      if (!bootStarted) {
        bootStarted = true;
        // Renderer + input wiring (waits for onFoxproReady), then
        // boot the wasm — both supplied by foxpro-go's foxpro.js.
        FoxproRender.attach(canvas);
        FoxproRender.bootWasm('/foxpro/sim.wasm');
      }
      canvas.focus();
    }
    function close() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
    }
    window.foxproOverlay = { open, close };

    toggle.addEventListener('click', open);

    // Visible X close button in the overlay corner.
    const closeBtn = document.getElementById('foxpro-close');
    closeBtn?.addEventListener('click', close);

    // Click on the dim backdrop (but not the canvas itself) closes.
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    // Esc behaves as a one-layer-at-a-time dismiss:
    //   1st Esc — the canvas's own keydown handler forwards it into
    //             foxpro. If a menu (or popup) is open inside foxpro,
    //             that closes first. We do NOT close the overlay yet.
    //   2nd Esc — within a short grace window, close the overlay.
    //
    // We can't query foxpro-go for "is a menu open" from outside the
    // wasm, so we use this two-step dismiss instead. Effect: Esc to
    // back out of menus naturally; Esc-Esc to leave the overlay.
    // The Esc-arming flag persists until either the second Esc fires
    // OR the user interacts with the overlay in any other way (clicks,
    // types a non-Esc key). The grace window is just a safety reset
    // so the flag doesn't linger forever in the background.
    const ESC_GRACE_MS = 2500;
    let lastEscAt = 0;
    document.addEventListener('keydown', (e) => {
      if (overlay.classList.contains('hidden')) return;
      if (e.key !== 'Escape') {
        // Any other key resets the "armed" state — the user is doing
        // something else inside foxpro, not trying to exit.
        lastEscAt = 0;
        return;
      }
      const now = Date.now();
      if (lastEscAt && now - lastEscAt < ESC_GRACE_MS) {
        close();
        lastEscAt = 0;
        return;
      }
      // First Esc — let the canvas (and foxpro) handle it. Mark the
      // press so a follow-up Esc within ~2.5s closes the overlay.
      lastEscAt = now;
    });
    // Mouse clicks inside the overlay also reset the arming.
    overlay.addEventListener('mousedown', () => { lastEscAt = 0; });
  })();
</script>
