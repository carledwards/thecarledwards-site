---
// FoxproOverlay — a full-viewport canvas that mounts a foxpro-go WASM
// "FoxPro Mode" on top of the page on demand.
//
// Render this once in BaseLayout.astro. The wasm is loaded lazily on
// first activation, then kept resident so subsequent toggles are instant.
//
// Talks to the wasm through window.foxproWasm (set by foxpro-go's
// browser bridge). The wasm talks back via window.siteAPI, defined in
// the inline script below — that's where Go-side menu items reach
// browser features (open URL, navigate, close overlay).
---

<button
  id="foxpro-toggle"
  type="button"
  aria-label="Toggle Retro FoxPro Mode"
  class="fixed bottom-4 right-4 z-40 overflow-hidden rounded-md border border-ink-700 bg-ink-900/90 px-3 py-2 font-mono text-xs text-ink-200 shadow-lg backdrop-blur transition hover:border-accent hover:text-accent"
>
  <span class="relative z-10">▣ Retro FoxPro Mode</span>
  <span class="foxpro-shimmer" aria-hidden="true"></span>
</button>

<style is:global>
  /* Sweep highlight that travels across the FoxPro Mode button every
     few seconds. Pulled to the side most of the cycle (translateX
     keyframes spend ~70% off-screen) so it reads as a periodic glint
     rather than a constant glow. Disabled for users who prefer
     reduced motion. */
  @keyframes foxpro-sheen {
    0%, 70% {
      transform: translateX(-110%);
    }
    100% {
      transform: translateX(220%);
    }
  }
  #foxpro-toggle .foxpro-shimmer {
    position: absolute;
    inset: 0;
    width: 50%;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(255, 255, 255, 0.22) 50%,
      transparent 100%
    );
    transform: translateX(-110%);
    animation: foxpro-sheen 4.5s ease-in-out infinite;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #foxpro-toggle .foxpro-shimmer {
      animation: none;
    }
  }
</style>

<div
  id="foxpro-overlay"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink-950/70 p-6 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="FoxPro Mode"
>
  <canvas
    id="foxpro-screen"
    tabindex="0"
    class="block max-h-[calc(100vh-3rem)] max-w-[calc(100vw-3rem)] rounded-md outline-none ring-1 ring-ink-700/60"
    style="image-rendering: pixelated; background:#0000aa; box-shadow: 0 30px 80px -20px rgba(0,0,0,0.8), 0 10px 30px -8px rgba(0,0,0,0.6);"
  ></canvas>
</div>

<script is:inline src="/foxpro/wasm_exec.js"></script>
<script is:inline>
  // siteAPI — the seam Go talks through. Defined before the wasm
  // boots so js.Global().Get("siteAPI").Call(...) inside the wasm
  // always finds these.
  window.siteAPI = {
    openURL: (url) =>
      window.open(url, '_blank', 'noopener,noreferrer'),
    navigate: (path) => window.location.assign(path),
    close: () => window.foxproOverlay && window.foxproOverlay.close(),
  };

  (() => {
    // Cell metrics. SF Mono / Menlo / generic monospace render glyphs
    // with descenders that extend ~25% below the alphabetic baseline.
    // CELL_H needs to leave room for that or letters like g, p, y, j
    // get sliced at the bottom. Rule of thumb: CELL_H >= FONT_PX * 1.4.
    const FONT_PX = 16;
    const CELL_H = 22;
    const DEFAULT_FG = '#cccccc';
    const DEFAULT_BG = '#0000aa';
    const DEFAULT_COLOR_SENTINEL = 0xff000000;

    const toggle = document.getElementById('foxpro-toggle');
    const overlay = document.getElementById('foxpro-overlay');
    const canvas = document.getElementById('foxpro-screen');
    const ctx = canvas.getContext('2d', { alpha: false });
    const logErr = (msg, err) => {
      console.error('[foxpro]', msg, err || '');
    };

    let cellW = 9;
    let buf = null;
    let view = null;
    let booted = false;
    let bootStarted = false;
    let stopped = false;

    function open() {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      if (!bootStarted) bootWasm();
      canvas.focus();
    }
    function close() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
    }
    window.foxproOverlay = { open, close };

    toggle.addEventListener('click', open);

    // Click on the dim backdrop (but not the canvas itself) closes.
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    // Esc dismisses the overlay unconditionally when it's open. The
    // canvas's own keydown handler still forwards Esc into foxpro
    // first (since canvas listeners run before document listeners),
    // so any open foxpro menu closes its popup state before the
    // overlay disappears — re-opening the overlay later won't show
    // a stale menu.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (overlay.classList.contains('hidden')) return;
      close();
    });

    async function bootWasm() {
      bootStarted = true;
      if (typeof Go === 'undefined') {
        logErr('wasm_exec.js failed to load');
        return;
      }
      const go = new Go();
      window.onFoxproReady = () => {
        if (booted) return;
        booted = true;
        wireScreen();
      };
      try {
        const r = await WebAssembly.instantiateStreaming(
          fetch('/foxpro/sim.wasm'),
          go.importObject,
        );
        go.run(r.instance);
      } catch (err) {
        logErr('wasm load error', err);
      }
    }

    function wireScreen() {
      const fw = window.foxproWasm;
      if (!fw) {
        logErr('foxproWasm bridge missing');
        return;
      }

      ctx.font = `${FONT_PX}px ui-monospace, "SF Mono", Menlo, Consolas, monospace`;
      ctx.textBaseline = 'top';
      cellW = Math.max(7, Math.ceil(ctx.measureText('M').width));

      const [w, h] = fw.size();
      canvas.width = w * cellW;
      canvas.height = h * CELL_H;
      // Re-set font: changing canvas dims clears state.
      ctx.font = `${FONT_PX}px ui-monospace, "SF Mono", Menlo, Consolas, monospace`;
      ctx.textBaseline = 'top';

      buf = new Uint8Array(w * h * 16);
      view = new DataView(buf.buffer);

      setupInput(fw);
      requestAnimationFrame(frame);
    }

    function frame() {
      if (stopped) return;
      requestAnimationFrame(frame);
      const fw = window.foxproWasm;
      if (!fw || !buf) return;

      let sz;
      try {
        sz = fw.snapshot(buf);
      } catch (err) {
        stopped = true;
        logErr('foxpro exited — refresh to restart', err);
        return;
      }
      const w = sz[0], h = sz[1];
      for (let y = 0; y < h; y++) {
        let off = y * w * 16;
        for (let x = 0; x < w; x++) {
          const ch = view.getUint32(off, true);
          const fg = view.getUint32(off + 4, true);
          const bg = view.getUint32(off + 8, true);
          off += 16;
          paintCell(x, y, ch, fg, bg);
        }
      }
    }

    function paintCell(x, y, ch, fg, bg) {
      const px = x * cellW;
      const py = y * CELL_H;
      ctx.fillStyle = colorToCSS(bg, DEFAULT_BG);
      ctx.fillRect(px, py, cellW, CELL_H);
      if (ch === 0 || ch === 32) return;
      const fgCss = colorToCSS(fg, DEFAULT_FG);
      // Box-drawing (U+2500–U+257F) and block (U+2580–U+258F) chars
      // get rendered as rect primitives so they connect cell-to-cell.
      // ctx.fillText for these glyphs leaves visible gaps because the
      // font's natural glyph width/height is < cellW / CELL_H.
      if (ch >= 0x2500 && ch <= 0x258F) {
        if (drawBoxOrBlock(px, py, ch, fgCss)) return;
      }
      ctx.fillStyle = fgCss;
      ctx.fillText(String.fromCodePoint(ch), px, py + 1);
    }

    // drawBoxOrBlock renders a Unicode box-drawing or block-element
    // glyph as fillRect primitives. Returns true if it handled the
    // codepoint, false to fall through to fillText.
    function drawBoxOrBlock(px, py, ch, fgCss) {
      ctx.fillStyle = fgCss;
      // Block elements first — solid rectangles, no font rendering.
      switch (ch) {
        case 0x2580: // ▀ upper half
          ctx.fillRect(px, py, cellW, Math.floor(CELL_H / 2));
          return true;
        case 0x2584: // ▄ lower half
          ctx.fillRect(px, py + Math.floor(CELL_H / 2), cellW, CELL_H - Math.floor(CELL_H / 2));
          return true;
        case 0x2588: // █ full block
          ctx.fillRect(px, py, cellW, CELL_H);
          return true;
        case 0x258C: // ▌ left half
          ctx.fillRect(px, py, Math.floor(cellW / 2), CELL_H);
          return true;
        case 0x2590: // ▐ right half
          ctx.fillRect(px + Math.floor(cellW / 2), py, cellW - Math.floor(cellW / 2), CELL_H);
          return true;
      }
      // Single-line box-drawing — extents from cell center toward
      // each edge, drawn as 1-px rects that meet at the center.
      // 0x2500–0x253C covers the most common subset (─│ corners
      // ├┤┬┴┼). Anything else falls through to fillText.
      let L = false, R = false, U = false, D = false;
      switch (ch) {
        case 0x2500: L = R = true; break;       // ─
        case 0x2502: U = D = true; break;       // │
        case 0x250C: R = D = true; break;       // ┌
        case 0x2510: L = D = true; break;       // ┐
        case 0x2514: R = U = true; break;       // └
        case 0x2518: L = U = true; break;       // ┘
        case 0x251C: U = D = R = true; break;   // ├
        case 0x2524: U = D = L = true; break;   // ┤
        case 0x252C: L = R = D = true; break;   // ┬
        case 0x2534: L = R = U = true; break;   // ┴
        case 0x253C: L = R = U = D = true; break; // ┼
        default: return false;
      }
      const cx = px + Math.floor(cellW / 2);
      const cy = py + Math.floor(CELL_H / 2);
      const lw = 1;
      // Each direction extends from the edge through the center pixel.
      // Pairs naturally overlap at (cx, cy) so no gap appears.
      if (L) ctx.fillRect(px, cy, cx - px + lw, lw);
      if (R) ctx.fillRect(cx, cy, px + cellW - cx, lw);
      if (U) ctx.fillRect(cx, py, lw, cy - py + lw);
      if (D) ctx.fillRect(cx, cy, lw, py + CELL_H - cy);
      return true;
    }

    function colorToCSS(c, fallback) {
      if (c === DEFAULT_COLOR_SENTINEL) return fallback;
      const r = (c >> 16) & 0xff;
      const g = (c >> 8) & 0xff;
      const b = c & 0xff;
      return `rgb(${r},${g},${b})`;
    }

    function setupInput(fw) {
      const KEYS = fw.keys, MODS = fw.mods, BTN = fw.buttons;

      const specialKeys = {
        Enter: KEYS.Enter,
        Tab: KEYS.Tab,
        Escape: KEYS.Esc,
        Backspace: KEYS.Backspace2,
        ArrowUp: KEYS.Up,
        ArrowDown: KEYS.Down,
        ArrowLeft: KEYS.Left,
        ArrowRight: KEYS.Right,
        Home: KEYS.Home,
        End: KEYS.End,
        PageUp: KEYS.PgUp,
        PageDown: KEYS.PgDn,
        Insert: KEYS.Insert,
        Delete: KEYS.Delete,
      };
      for (let i = 1; i <= 12; i++) specialKeys['F' + i] = KEYS['F' + i];

      canvas.addEventListener('keydown', (e) => {
        if (e.metaKey) return; // let Cmd+R, Cmd+L, etc. through.
        const mods =
          (e.shiftKey ? MODS.Shift : 0) |
          (e.ctrlKey ? MODS.Ctrl : 0) |
          (e.altKey ? MODS.Alt : 0) |
          (e.metaKey ? MODS.Meta : 0);
        if (e.key === 'Tab' && e.shiftKey) {
          e.preventDefault();
          fw.injectKey(KEYS.Backtab, 0, mods);
          return;
        }
        const sk = specialKeys[e.key];
        if (sk !== undefined) {
          e.preventDefault();
          fw.injectKey(sk, 0, mods);
          return;
        }
        if (e.altKey && /^Key[A-Z]$/.test(e.code)) {
          e.preventDefault();
          fw.injectKey(KEYS.Rune, e.code.charCodeAt(3) + 32, mods);
          return;
        }
        if (e.key.length === 1) {
          e.preventDefault();
          fw.injectKey(KEYS.Rune, e.key.codePointAt(0), mods);
        }
      });

      function pixelToCell(e) {
        const r = canvas.getBoundingClientRect();
        const px = (e.clientX - r.left) * (canvas.width / r.width);
        const py = (e.clientY - r.top) * (canvas.height / r.height);
        return [Math.floor(px / cellW), Math.floor(py / CELL_H)];
      }
      function buttonsMaskFromEvent(e) {
        let m = 0;
        if (e.buttons & 1) m |= BTN.Primary;
        if (e.buttons & 2) m |= BTN.Secondary;
        if (e.buttons & 4) m |= BTN.Middle;
        return m;
      }
      function modMaskFromEvent(e) {
        let m = 0;
        if (e.shiftKey) m |= MODS.Shift;
        if (e.ctrlKey) m |= MODS.Ctrl;
        if (e.altKey) m |= MODS.Alt;
        if (e.metaKey) m |= MODS.Meta;
        return m;
      }

      canvas.addEventListener('mousedown', (e) => {
        e.preventDefault();
        canvas.focus();
        const [cx, cy] = pixelToCell(e);
        fw.injectMouse(cx, cy, buttonsMaskFromEvent(e), modMaskFromEvent(e));
      });
      canvas.addEventListener('mousemove', (e) => {
        const [cx, cy] = pixelToCell(e);
        fw.injectMouse(cx, cy, buttonsMaskFromEvent(e), modMaskFromEvent(e));
      });
      canvas.addEventListener('mouseup', (e) => {
        e.preventDefault();
        const [cx, cy] = pixelToCell(e);
        fw.injectMouse(cx, cy, buttonsMaskFromEvent(e), modMaskFromEvent(e));
      });
      canvas.addEventListener('contextmenu', (e) => e.preventDefault());
      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        const [cx, cy] = pixelToCell(e);
        let btn = 0;
        if (e.deltaY < 0) btn = BTN.WheelUp;
        else if (e.deltaY > 0) btn = BTN.WheelDown;
        else if (e.deltaX < 0) btn = BTN.WheelLeft;
        else if (e.deltaX > 0) btn = BTN.WheelRight;
        if (btn) fw.injectMouse(cx, cy, btn, modMaskFromEvent(e));
      }, { passive: false });
    }
  })();
</script>
