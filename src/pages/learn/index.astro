---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = (await getCollection('lessons', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

type Lesson = (typeof all)[number];

// Explicit series order on the /learn index. Series listed here
// appear in this order; any others fall in after, in the order
// their first lesson is encountered.
const SERIES_ORDER = ['binary', 'computer', '6502', 'building'];

const seriesMap = new Map<string, { title: string; lessons: Lesson[] }>();
for (const l of all) {
  const key = l.data.series;
  const entry = seriesMap.get(key) ?? { title: l.data.seriesTitle, lessons: [] };
  entry.lessons.push(l);
  seriesMap.set(key, entry);
}

const seriesList = Array.from(seriesMap.entries()).sort(([a], [b]) => {
  const ai = SERIES_ORDER.indexOf(a);
  const bi = SERIES_ORDER.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

// Reference pages that belong to a series but aren't lessons. Surfaced
// in that series' block so they're discoverable from the index.
const seriesRefs: Record<string, { href: string; label: string }[]> = {
  '6502': [
    { href: '/learn/6502/syntax', label: 'Assembly syntax' },
    { href: '/learn/6502/machine', label: 'More about the 6502' },
    { href: '/learn/6502/built', label: 'How CodeLab is built' },
  ],
};
---

<BaseLayout
  title="Learn"
  description="Hands-on lessons by Carl Edwards that build up the smallest useful model of a computer — from a single bit to a working 8-bit CPU running real code."
>
  <section class="container-wide py-20">
    <div class="text-mono-tag mb-4">Learn</div>
    <h1 class="text-4xl sm:text-5xl font-semibold text-ink-100 tracking-tight">
      From bits to a real machine.
    </h1>
    <p class="mt-4 max-w-2xl text-ink-300">
      Hands-on lessons that build up the smallest useful model of a
      computer — starting from a single bit and ending with a working
      8-bit CPU running real code. Click things, watch them change, build
      intuition. Friendly even if you've never written code.
    </p>
  </section>

  <section class="container-wide pb-20">
    <div class="max-w-2xl border-l-2 border-accent/50 pl-5 sm:pl-6">
      <div class="text-mono-tag mb-3">Why this exists</div>
      <div class="space-y-4 text-ink-300 leading-relaxed">
        <p>
          Binary, "binary math," how a chip actually runs — these get a
          reputation for being elusive. I don't think they're hard. They're
          usually explained from the top down, in the abstract, and the
          moment where it would have clicked gets skipped. People who'd
          given up on binary have walked through this and now get it.
          That's the whole point — fill the gap, not guard it.
        </p>
        <p>
          So it runs the other way: by hand, by doing, the smallest real
          version of each idea, built by you — and built AI-forward, so you
          can pull the full context into your assistant whenever you want
          to go deeper.
          <a class="text-accent hover:underline" href="/blog/from-a-single-bit-to-a-real-cpu/">Here's the story behind it&nbsp;→</a>
        </p>
      </div>
    </div>
  </section>

  <section class="container-wide pb-10">
    <div class="text-mono-tag mb-3">Jump to</div>
    <div class="flex flex-wrap gap-2">
      {seriesList.map(([key, { title }]) => (
        <a
          href={`#${key}`}
          class="rounded-md border border-ink-800 bg-ink-900 px-3 py-1.5 text-sm text-ink-300 hover:border-accent hover:text-accent"
        >
          {title}
        </a>
      ))}
    </div>
  </section>

  <section class="container-wide pb-24 space-y-12">
    {seriesList.map(([key, { title, lessons }]) => (
      <div id={key} class="scroll-mt-8 rounded-lg border border-ink-800 bg-ink-900 overflow-hidden">
        <div class="p-6 sm:p-8 border-b border-ink-800">
          <div class="text-mono-tag mb-2">Series</div>
          <h2 class="text-2xl font-semibold tracking-tight text-ink-100">
            {title}
          </h2>
          <p class="mt-2 text-ink-400 text-sm">
            {lessons.length} lesson{lessons.length === 1 ? '' : 's'}
          </p>
          {seriesRefs[key] && (
            <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm">
              <span class="font-mono text-[11px] uppercase tracking-wider text-ink-500">References</span>
              {seriesRefs[key].map((r) => (
                <a class="text-accent hover:underline" href={r.href}>{r.label}</a>
              ))}
            </div>
          )}
        </div>
        <ul class="divide-y divide-ink-800">
          {lessons.map((l) => (
            <li>
              <a
                href={`/learn/${l.slug}/`}
                class="group flex flex-col gap-2 p-6 sm:flex-row sm:items-baseline sm:gap-6 hover:bg-ink-800/30"
              >
                <span class="font-mono text-xs uppercase tracking-wider text-ink-500 sm:w-20 shrink-0">
                  {String(l.data.order).padStart(2, '0')}
                </span>
                <div class="min-w-0 flex-1">
                  <div class="text-lg text-ink-100 font-medium group-hover:text-accent tracking-tight">
                    {l.data.title}
                  </div>
                  <p class="mt-1.5 text-sm text-ink-400 leading-relaxed">
                    {l.data.summary}
                  </p>
                  {l.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {l.data.tags.slice(0, 4).map((t) => (
                        <span class="font-mono text-[10px] uppercase tracking-wider text-ink-500 bg-ink-800/60 px-2 py-0.5 rounded">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
