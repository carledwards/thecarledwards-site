---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const groupedByYear = posts.reduce<Record<string, typeof posts>>((acc, p) => {
  const y = p.data.date.getFullYear().toString();
  acc[y] = acc[y] ?? [];
  acc[y].push(p);
  return acc;
}, {});
const years = Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Writing" description="Essays and notes by Carl Edwards on engineering, systems, and AI tooling.">
  <section class="container-wide py-20">
    <div class="text-mono-tag mb-4">// writing</div>
    <h1 class="text-4xl sm:text-5xl font-semibold text-ink-100 tracking-tight">
      Notes from the work.
    </h1>
    <p class="mt-4 max-w-2xl text-ink-300">
      Essays on engineering, leadership, AI-native workflows, and the occasional weekend
      diversion. {posts.length} posts and counting.
    </p>
  </section>

  <section class="container-wide pb-24">
    {years.map((year) => (
      <div class="mb-12">
        <div class="flex items-baseline gap-4 mb-4 border-b border-ink-800 pb-3">
          <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-ink-400">{year}</h2>
          <span class="text-xs text-ink-500">{groupedByYear[year].length} posts</span>
        </div>
        <ul class="divide-y divide-ink-800">
          {groupedByYear[year].map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`} class="group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:gap-6">
                <time class="font-mono text-xs uppercase tracking-wider text-ink-500 sm:w-28 shrink-0" datetime={p.data.date.toISOString()}>
                  {fmt(p.data.date)}
                </time>
                <div class="min-w-0 flex-1">
                  <div class="text-lg text-ink-100 font-medium group-hover:text-accent tracking-tight">
                    {p.data.title}
                  </div>
                  {p.data.description && (
                    <p class="mt-1.5 text-sm text-ink-400 leading-relaxed">{p.data.description}</p>
                  )}
                  {p.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {p.data.tags.slice(0, 4).map((t) => (
                        <span class="font-mono text-[10px] uppercase tracking-wider text-ink-500 bg-ink-800/60 px-2 py-0.5 rounded">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
